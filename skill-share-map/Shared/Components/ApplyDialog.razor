@using SkillShareMap.Models
@using Microsoft.AspNetCore.Components
@using MudBlazor

<MudDialog>
    <DialogContent>
        <MudText Class="mb-3">Enter your offer and a message to the creator.</MudText>
        <MudNumericField @bind-Value="Price" Label="Your Offer ($)" Variant="Variant.Outlined" Min="0" Format="F2" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AttachMoney" />
        <MudTextField @bind-Value="Message" Label="Message (Why pick you?)" Variant="Variant.Outlined" Lines="3" Class="mt-3" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">Submit Application</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] 
    public IMudDialogInstance MudDialog { get; set; } = default!;
    
    [Parameter] public string TaskTitle { get; set; } = string.Empty;
    [Parameter] public decimal Budget { get; set; }

    private decimal Price;
    private string Message = string.Empty;

    protected override void OnInitialized()
    {
        Price = Budget;
    }

    void Submit()
    {
        MudDialog.Close(DialogResult.Ok(new Tuple<decimal, string>(Price, Message)));
    }

    void Cancel() => MudDialog.Cancel();
}