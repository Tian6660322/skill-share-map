@namespace SkillShareMap.Shared.Components
@implements IDisposable
@inject IJSRuntime JS

<div id="@MapId" style="height: @Height; width: 100%;"></div>

@code {
    private DotNetObjectReference<MapComponent>? _dotNetRef;

    [Parameter]
    public string MapId { get; set; } = "map";

    [Parameter]
    public string Height { get; set; } = "500px";

    [Parameter]
    public double InitialLat { get; set; } = -33.8688;

    [Parameter]
    public double InitialLng { get; set; } = 151.2093;

    [Parameter]
    public int InitialZoom { get; set; } = 13;

    [Parameter]
    public EventCallback<int> OnMarkerClick { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("mapHelper.initMap", MapId, InitialLat, InitialLng, InitialZoom, _dotNetRef);
        }
    }

    public async Task AddMarkerAsync(int id, double lat, double lng, string title, string type = "task")
    {
        await JS.InvokeVoidAsync("mapHelper.addMarker", id, lat, lng, title, type);
    }

    public async Task ClearMarkersAsync()
    {
        await JS.InvokeVoidAsync("mapHelper.clearMarkers");
    }

    public async Task FitBoundsAsync()
    {
        await JS.InvokeVoidAsync("mapHelper.fitBounds");
    }

    public async Task SetViewAsync(double lat, double lng, int zoom = 13)
    {
        await JS.InvokeVoidAsync("mapHelper.setView", lat, lng, zoom);
    }

    [JSInvokable]
    public Task HandleMarkerClick(int markerId)
    {
        if (OnMarkerClick.HasDelegate)
        {
            return OnMarkerClick.InvokeAsync(markerId);
        }

        return Task.CompletedTask;
    }

    public void Dispose()
    {
        _dotNetRef?.Dispose();
    }
}
