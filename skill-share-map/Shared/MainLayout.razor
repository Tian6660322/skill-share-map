@inherits LayoutComponentBase

@namespace SkillShareMap.Shared
@inject NavigationManager Navigation
@inject SkillShareMap.Services.UserState UserState
@inject SkillShareMap.Services.IChatService ChatService

<MudPopoverProvider />
<MudThemeProvider Theme="AppTheme.Default" />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Fixed="true" Style="background-color: #ffffff; border-bottom: 1px solid #e0e0e0; color: #4a4a4a;">
        
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mr-8 cursor-pointer" onclick="location.href='/'">
            <MudImage Src="images/logo.png" Height="40" Alt="Logo" Class="mr-2"/>
        </MudStack>

        <MudStack Row="true" Spacing="8" AlignItems="AlignItems.Center" Class="d-none d-md-flex">
            
            <MudLink Href="/" Underline="Underline.None" Color="Color.Secondary" Style="font-weight: 500;">Home</MudLink>
            
            <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mx-2">/</MudText>

            <MudLink Href="/classroom" Underline="Underline.None" Color="Color.Secondary" Style="font-weight: 500;">Classroom</MudLink>
            
            <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mx-2">/</MudText>

            <MudLink Href="/ai-assistant" Underline="Underline.None" Color="Color.Secondary" Style="font-weight: 500;">AI Coach</MudLink>
        
        </MudStack>

        <MudButton Variant="Variant.Filled" 
                   Color="Color.Secondary" 
                   Href="/post-task"
                   Class="ml-12 px-6 rounded"
                   Style="color: white; text-transform: none; font-weight: 600;">
            Post a Task
        </MudButton>

        <MudSpacer />

        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
            
            <MudTooltip Text="Messages">
                <MudIconButton Icon="@Icons.Material.Outlined.ChatBubbleOutline" Color="Color.Inherit" Href="/chats" />
            </MudTooltip>

                 @if (UserState.IsAuthenticated)
                {
                    <MudButton Variant="Variant.Text" 
                               Color="Color.Inherit" 
                               Href="/profile" 
                               StartIcon="@Icons.Material.Filled.Person"
                               Style="text-transform: none; font-weight: 600;">
                        My Profile
                    </MudButton>
                }
                else
                {
                    <MudButton Variant="Variant.Text" 
                               Color="Color.Inherit" 
                               Href="/login"
                               Style="text-transform: none; font-weight: 600;">
                        Log in
                    </MudButton>
                
                    <MudButton Variant="Variant.Outlined" 
                               Color="Color.Inherit" 
                               Href="/register"
                               Class="rounded-pill px-4"
                               Style="text-transform: none; font-weight: 600; border-color: #333;">
                        Sign up
                    </MudButton>
                }
        </MudStack>

    </MudAppBar>

    <MudMainContent Class="pt-20">
        @Body
    </MudMainContent>
</MudLayout>