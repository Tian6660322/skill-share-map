@page "/post-task"
@using SkillShareMap.Services
@using SkillShareMap.Models
@using Microsoft.JSInterop
@using System.IO
@inject ITaskService TaskService
@inject IGeoService GeoService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject UserState UserState
@inject IJSRuntime JSRuntime
@inject IWebHostEnvironment Environment

<PageTitle>Post a Task</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="my-8">
    
    <div class="mb-8">
        <MudText Typo="Typo.h4" Style="font-weight: 700; color: #1B1B1B;">
            Post a new task
        </MudText>
        
        <div class="d-flex align-center mt-2">
            <MudAvatar Color="Color.Primary" Size="Size.Small" Class="mr-2">
                @if (!string.IsNullOrEmpty(UserState.CurrentUser?.Username))
                {
                    <MudText Typo="Typo.caption" style="color:white;">@UserState.CurrentUser.Username.Substring(0, 1).ToUpper()</MudText>
                }
            </MudAvatar>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Post by <b>@(UserState.CurrentUser?.Username ?? "Guest")</b>
            </MudText>
        </div>
    </div>

    <MudForm @ref="_form" @bind-IsValid="@_formValid">

        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Task Category</MudText>
        <MudSelect T="TaskCategory?" MultiSelection="true" @bind-SelectedValues="_selectedCategories"
                   Placeholder="Select categories"
                   Variant="Variant.Outlined" 
                   AnchorOrigin="Origin.BottomCenter"
                   Class="mb-6 rounded-lg"
                   AdornmentIcon="@Icons.Material.Filled.KeyboardArrowDown"
                   AdornmentColor="Color.Primary">
            
            <MudSelectItem T="TaskCategory?" Value="null" Disabled="true" Class="pa-0">
                <MudTextField @bind-Value="_categorySearchText" 
                              Placeholder="Search categories..."
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Class="mx-2 mt-2"
                              Immediate="true"
                              Variant="Variant.Outlined" 
                              Margin="Margin.Dense" />
                              @* Removed OnClick to fix compilation error CS8917 *@
            </MudSelectItem>

            @foreach (var category in Enum.GetValues<TaskCategory>().Where(c => string.IsNullOrEmpty(_categorySearchText) || c.ToString().Contains(_categorySearchText, StringComparison.OrdinalIgnoreCase)))
            {
                <MudSelectItem T="TaskCategory?" Value="@(category)">@GetCategoryName(category)</MudSelectItem>
            }
        </MudSelect>
        
        @if (_selectedCategories.Any())
        {
            <div class="d-flex flex-wrap gap-2 mb-6 mt-n4">
                @foreach (var cat in _selectedCategories)
                {
                    <MudChip T="TaskCategory?" 
                             Color="Color.Primary" 
                             Size="Size.Small" 
                             OnClose="@(() => _selectedCategories = _selectedCategories.Where(c => c != cat).ToList())" 
                             Class="rounded-lg">
                        @GetCategoryName(cat.Value)
                    </MudChip>
                }
            </div>
        }

        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Task Title</MudText>
        <MudTextField @bind-Value="_task.Title" 
                      Placeholder="e.g. Create a ios app design" 
                      Variant="Variant.Outlined" 
                      Class="mb-6 rounded-lg" 
                      Required="true"
                      MaxLength="100"/>

        <MudGrid Class="mb-2">
            <MudItem xs="8">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Deadline</MudText>
                <MudDatePicker @bind-Date="_deadline" 
                               Placeholder="Select date" 
                               Variant="Variant.Outlined"
                               Class="rounded-lg"
                               MinDate="DateTime.Today" 
                               Required="true"
                               AdornmentIcon="@Icons.Material.Filled.CalendarToday"
                               AdornmentColor="Color.Primary" />
            </MudItem>
            <MudItem xs="4" Class="d-flex flex-column justify-center align-center">
                 <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Urgent?</MudText>
                 <MudSwitch @bind-Value="_task.IsUrgent" Color="Color.Primary" UnCheckedColor="Color.Default" />
            </MudItem>
        </MudGrid>

        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1 mt-4">Description</MudText>
        <MudTextField @bind-Value="_task.Description" 
                      Placeholder="Describe your task in detail..." 
                      Variant="Variant.Outlined" 
                      Lines="6" 
                      Class="mb-6 rounded-lg" 
                      Required="true" 
                      MaxLength="500"/>

        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Budget</MudText>
        <MudNumericField @bind-Value="_task.Budget" 
                         Placeholder="0" 
                         Variant="Variant.Outlined" 
                         Class="mb-6 rounded-lg" 
                         Min="0" 
                         Step="10"
                         Adornment="Adornment.Start"
                         AdornmentIcon="@Icons.Material.Filled.AttachMoney"/>

        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Location Type</MudText>
        <div class="d-flex gap-3 mb-6">
            <MudButton Variant="@(_task.LocationType == TaskLocationType.OnSite ? Variant.Filled : Variant.Outlined)"
                       Color="@(_task.LocationType == TaskLocationType.OnSite ? Color.Primary : Color.Default)"
                       OnClick="@(() => SetLocationType(TaskLocationType.OnSite))"
                       Class="rounded-lg px-6"
                       Style="text-transform:none; font-weight:600; width: 120px;">
                Onsite
            </MudButton>

            <MudButton Variant="@(_task.LocationType == TaskLocationType.Remote ? Variant.Filled : Variant.Outlined)"
                       Color="@(_task.LocationType == TaskLocationType.Remote ? Color.Primary : Color.Default)"
                       OnClick="@(() => SetLocationType(TaskLocationType.Remote))"
                       Class="rounded-lg px-6"
                       Style="text-transform:none; font-weight:600; width: 120px;">
                Remote
            </MudButton>
        </div>

        @if (_task.LocationType == TaskLocationType.OnSite)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Location</MudText>
            
            <MudAutocomplete T="LocationResult"
                             Value="_selectedLocation"
                             ValueChanged="OnLocationSelected"
                             SearchFunc="@SearchAddress"
                             ToStringFunc="@(x => x?.DisplayName ?? "")"
                             Placeholder="Enter address..."
                             Variant="Variant.Outlined"
                             Class="mb-6 rounded-lg"
                             Adornment="Adornment.End"
                             AdornmentIcon="@Icons.Material.Filled.MyLocation"
                             AdornmentColor="Color.Primary"
                             OnAdornmentClick="GetCurrentLocation"
                             Required="true">
                 <ProgressIndicator>
                     <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" />
                 </ProgressIndicator>
            </MudAutocomplete>
        }

        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Materials</MudText>
        <div class="d-flex gap-3 mb-8">
            <MudFileUpload T="IBrowserFile" FilesChanged="UploadFiles">
                <ActivatorContent>
                     <MudPaper Class="d-flex justify-center align-center rounded-lg cursor-pointer border-dashed" 
                              Style="width: 60px; height: 60px; border: 1px dashed #7B9CC9;">
                        <MudIcon Icon="@Icons.Material.Filled.Add" Color="Color.Primary" />
                    </MudPaper>
                </ActivatorContent>
            </MudFileUpload>

            @if (!string.IsNullOrEmpty(_task.AttachmentUrl))
            {
                <MudTooltip Text="File Uploaded">
                    <MudPaper Class="d-flex flex-column justify-center align-center rounded-lg" 
                              Style="width: 60px; height: 60px; background-color: #E3F2FD;">
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Primary" />
                    </MudPaper>
                </MudTooltip>
            }
        </div>

        <div class="d-flex justify-end gap-3 mb-12">
            <MudButton OnClick="Cancel" 
                       Variant="Variant.Outlined" 
                       Class="rounded-lg px-6"
                       Color="Color.Secondary"
                       Style="text-transform:none; font-weight:600; border-color: #e0e0e0;">
                Cancel
            </MudButton>

            <MudButton OnClick="SubmitTask" 
                       Variant="Variant.Filled" 
                       Color="Color.Primary" 
                       Disabled="@(!CanSubmit())"
                       Class="rounded-lg px-8"
                       Style="text-transform:none; font-weight:600;">
                @if (_isSubmitting)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" Color="Color.Surface"/>
                    <text>Posting...</text>
                }
                else
                {
                    <text>Post Task</text>
                }
            </MudButton>
        </div>

    </MudForm>
</MudContainer>

<style>
    body, .mud-typography, .mud-input-control {
        font-family: 'IBM Plex Sans', 'Mona Sans', sans-serif !important;
    }
    
    .mud-input-control-input-container {
        background-color: white !important;
    }

    .mud-chip-text {
        font-size: 12px;
    }
</style>

@code {
    private MudForm _form;
    private bool _formValid;
    private bool _isSubmitting;
    private bool _isLoadingLocation;
    private DateTime? _deadline = DateTime.Today.AddDays(7);
    
    private string _categorySearchText = "";
    
    private IEnumerable<TaskCategory?> _selectedCategories = new HashSet<TaskCategory?>();
    
    private LocationResult? _selectedLocation;

    private SkillTask _task = new SkillTask
    {
        Budget = 0,
        Status = SkillTaskStatus.Open,
        LocationType = TaskLocationType.OnSite
    };

    protected override void OnInitialized()
    {
        if (!UserState.IsAuthenticated || UserState.CurrentUser == null)
        {
            Navigation.NavigateTo("/login");
            return;
        }
        _task.CreatorId = UserState.CurrentUser.Id;
    }

    private void SetLocationType(TaskLocationType type)
    {
        _task.LocationType = type;
        if (type == TaskLocationType.Remote)
        {
            _task.LocationAddress = null;
            _task.Latitude = null;
            _task.Longitude = null;
            _selectedLocation = null;
        }
    }

    private bool CanSubmit()
    {
        if (string.IsNullOrWhiteSpace(_task.Title)) return false;
        if (string.IsNullOrWhiteSpace(_task.Description)) return false;
        if (!_selectedCategories.Any()) return false;
        
        if (_task.LocationType == TaskLocationType.OnSite && _task.Latitude == null) return false;

        return true;
    }

    private async Task GetCurrentLocation()
    {
        _isLoadingLocation = true;
        try
        {
            var locationData = await JSRuntime.InvokeAsync<LocationData>(
                "geolocationHelper.getCurrentLocationWithAddress"
            );

            if (locationData != null)
            {
                _task.Latitude = locationData.Latitude;
                _task.Longitude = locationData.Longitude;
                _task.LocationAddress = locationData.Address;

                _selectedLocation = new LocationResult 
                { 
                    DisplayName = locationData.Address, 
                    Lat = locationData.Latitude, 
                    Lon = locationData.Longitude 
                };
                Snackbar.Add("Location detected", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("Could not detect location. Please allow GPS.", Severity.Warning);
        }
        finally
        {
            _isLoadingLocation = false;
        }
    }

    private async Task<IEnumerable<LocationResult>> SearchAddress(string value, CancellationToken token)
    {
        if (string.IsNullOrEmpty(value) || value.Length < 3)
            return new List<LocationResult>();
        try
        {
            return await GeoService.SearchAddressAsync(value);
        }
        catch
        {
            return new List<LocationResult>();
        }
    }

    private void OnLocationSelected(LocationResult result)
    {
        _selectedLocation = result;
        if (result != null)
        {
            _task.LocationAddress = result.DisplayName;
            _task.Latitude = result.Lat;
            _task.Longitude = result.Lon;
        }
    }

    private async Task UploadFiles(IBrowserFile file)
    {
        if (file == null) return;
        try
        {
            var uploadPath = Path.Combine(Environment.WebRootPath, "uploads");
            if (!Directory.Exists(uploadPath)) Directory.CreateDirectory(uploadPath);

            var fileName = $"{Guid.NewGuid()}{Path.GetExtension(file.Name)}";
            var filePath = Path.Combine(uploadPath, fileName);

            await using FileStream fs = new(filePath, FileMode.Create);
            await file.OpenReadStream(10 * 1024 * 1024).CopyToAsync(fs); 

            _task.AttachmentUrl = $"/uploads/{fileName}";
            Snackbar.Add("File attached", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Upload failed", Severity.Error);
        }
    }

    private async Task SubmitTask()
    {
        await _form.Validate();
        if (!CanSubmit()) return;

        _isSubmitting = true;
        try
        {
            if (_deadline.HasValue) _task.Deadline = _deadline.Value;

            if (_selectedCategories.Any())
            {
                _task.Category = _selectedCategories.First()!.Value;
            }

            var createdTask = await TaskService.CreateTaskAsync(_task);

            if (createdTask != null)
            {
                Snackbar.Add("Task posted!", Severity.Success);
                Navigation.NavigateTo("/");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void Cancel() => Navigation.NavigateTo("/");

    private class LocationData
    {
        public double Latitude { get; set; }
        public double Longitude { get; set; }
        public string Address { get; set; } = string.Empty;
    }

    private string GetCategoryName(TaskCategory category)
    {
        return category switch
        {
            TaskCategory.StudyHelp => "Study Help",
            TaskCategory.TechHelp => "Tech Help",
            TaskCategory.CreativeDesign => "Creative Design",
            TaskCategory.PhotoVideo => "Photo & Video",
            TaskCategory.WritingEditing => "Writing & Editing",
            TaskCategory.LanguageHelp => "Language Help",
            _ => category.ToString()
        };
    }
}