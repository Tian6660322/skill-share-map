    @code {

    [Parameter]
    public int? UserId { get; set; }

    private User? _user;
    private List<SkillTask> _userTasks = new();
    private List<Rating> _ratings = new();
    private List<UserBadge> _badges = new();

    // Explicitly using Models namespace to avoid conflict with Page class name
    private SkillShareMap.Models.Wallet? _wallet;
    private List<WalletTransaction> _walletTransactions = new();

    // Chat Data
    private List<ConversationSummary> _conversations = new();

    private bool _isLoading = true;
    private bool _isCurrentUser = false;

    // UI State
    private string _activeTab = "Task"; 
    private string _searchString = "";
    private bool _showCreatedTasks = true;

    // --- Profile Editing State (Added these missing variables) ---
    private bool _isEditingProfile = false;
    private bool _isEditingAddress = false;

    // New Fields for Profile (Skills & File Upload)
    private IEnumerable<TaskCategory> _selectedSkills = new HashSet<TaskCategory>();
    private string? _uploadedFileName;

    // --- Password Change State ---
    private MudForm _passwordForm;
    private string _currentPassword = "";
    private string _newPassword = "";
    private string _confirmPassword = "";

    // --- Verification State ---
    private string? _uploadedCertName;
    private bool _isVerified = false;
    private bool _hasPendingRequest = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadProfile();
    }

    private async Task LoadProfile()
    {
        _isLoading = true;
        try
        {
            int currentUserId = UserState.CurrentUser?.Id ?? 0;
            int profileUserId = UserId ?? currentUserId;

            if (profileUserId == 0)
            {
                Navigation.NavigateTo("/login");
                return;
            }

            _isCurrentUser = (currentUserId == profileUserId);
            _user = await AuthService.GetUserByIdAsync(profileUserId);

            if (_user != null)
            {
                // 1. Load Tasks
                var allTasks = await TaskService.GetTasksAsync();
                _userTasks = allTasks.Where(t => t.CreatorId == _user.Id || t.AssignedToId == _user.Id).ToList();

                // 2. Load Ratings & Badges
                _ratings = await RatingService.GetRatingsForUserAsync(_user.Id);
                if (_user.Role == UserRole.Student)
                {
                    _badges = await RatingService.GetUserBadgesAsync(_user.Id);
                }

                // 3. Load Private Data (Wallet & Chat) only if viewing own profile
                if (_isCurrentUser) 
                {
                    await LoadWalletData(profileUserId);
                    await LoadChatData(profileUserId);
                }
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadWalletData(int userId)
    {
        _wallet = await WalletService.GetWalletByUserIdAsync(userId);
        if (_wallet != null)
        {
            _walletTransactions = await WalletService.GetTransactionHistoryAsync(userId);
        }
    }

    private async Task LoadChatData(int userId)
    {
        var allMessages = await ChatService.GetUserMessagesAsync(userId);

        var grouped = allMessages
            .GroupBy(m => new { 
                OtherUserId = m.SenderId == userId ? m.ReceiverId : m.SenderId, 
                TaskId = m.TaskId 
            })
            .Select(g => new
            {
                g.Key.OtherUserId,
                g.Key.TaskId,
                Messages = g.OrderByDescending(m => m.SentAt).ToList()
            })
            .ToList();

        _conversations.Clear();

        foreach (var group in grouped)
        {
            var otherUser = await AuthService.GetUserByIdAsync(group.OtherUserId);
            if (otherUser == null) continue;

            var lastMessage = group.Messages.First();
            var unreadCount = group.Messages.Count(m => m.ReceiverId == userId && !m.IsRead);

            _conversations.Add(new ConversationSummary
            {
                OtherUser = otherUser,
                TaskId = group.TaskId,
                LastMessageContent = lastMessage.Type == MessageType.PriceNegotiation ? $"Negotiation: ${lastMessage.ProposedPrice}" : lastMessage.Content,
                LastMessageTime = lastMessage.SentAt,
                UnreadCount = unreadCount
            });
        }

        _conversations = _conversations.OrderByDescending(c => c.LastMessageTime).ToList();
    }

    // --- Task UI Helpers ---
    private List<SkillTask> GetDisplayedTasks()
    {
        IEnumerable<SkillTask> query = _userTasks;

        if (_showCreatedTasks) 
            query = query.Where(t => t.CreatorId == _user?.Id);
        else 
            query = query.Where(t => t.AssignedToId == _user?.Id);

        if (!string.IsNullOrWhiteSpace(_searchString))
            query = query.Where(t => t.Title.Contains(_searchString, StringComparison.OrdinalIgnoreCase));

        return query.OrderByDescending(t => t.CreatedAt).ToList();
    }

    private string GetStatusStyle(SkillTaskStatus status)
    {
        return status switch
        {
            SkillTaskStatus.Assigned => "background-color: #e45f2b; color: white;",
            SkillTaskStatus.Open => "background-color: #a0e548; color: white;",
            SkillTaskStatus.Completed => "background-color: #f6c445; color: white;",
            _ => "background-color: #E0E0E0; color: #616161;"
        };
    }

    // --- Sidebar Helpers ---
    private string GetSidebarClass(string tabName)
    {
        string commonClass = "d-flex align-center py-3 px-6 rounded-pill cursor-pointer";

        if (_activeTab == tabName)
            // ŃˇÖĐ×´Ě¬ŁşĚíĽÓÎŇĂÇ¸Ő˛Ĺ¶¨ŇĺµÄ .sidebar-selected Ŕŕ
            return $"{commonClass} sidebar-selected"; 
        else
            return $"{commonClass} hover-menu-item"; 
    }

    private string GetSidebarTextStyle(string tabName)
    {
        if (_activeTab == tabName)
            return "font-weight: 700; color: #000000;"; // Selected: Bold Black
        else
            return "font-weight: 500; color: #4a4a4a;"; // Unselected: Dark Grey
    }

    private string GetCategoryName(TaskCategory category) => category.ToString();

    private Color GetBadgeColor(BadgeTier tier) 
    {
        return tier switch 
        {
            BadgeTier.Expert => Color.Warning,
            BadgeTier.Advanced => Color.Info,
            _ => Color.Primary
        };
    }

    // --- Profile Editing Handlers ---
    private async Task ToggleEditProfile()
    {
        if (_isEditingProfile)
        {
            // User clicked "Save"
            if (_user != null)
            {
                // 1. Call backend service to persist data
                bool success = await AuthService.UpdateUserAsync(_user);

                if (success)
                {
                    Snackbar.Add("Profile updated successfully!", Severity.Success);
                }
                else
                {
                    Snackbar.Add("Failed to update profile.", Severity.Error);
                    return; // Keep in edit mode on failure
                }
            }
        }

        _isEditingProfile = !_isEditingProfile;
    }

    private async Task ToggleEditAddress()
    {
        if (_isEditingAddress)
        {
            // User clicked "Save"
            if (_user != null)
            {
                // 1. Call backend service to persist data
                bool success = await AuthService.UpdateUserAsync(_user);

                if (success)
                {
                    Snackbar.Add("Address updated successfully!", Severity.Success);
                }
                else
                {
                    Snackbar.Add("Failed to update address.", Severity.Error);
                    return;
                }
            }
        }

        _isEditingAddress = !_isEditingAddress;
    }

    // --- File Upload Helper ---
    private void UploadFiles(IBrowserFile file)
    {
        // For demonstration, we just store the name. In a real app, upload to server.
        _uploadedFileName = file.Name;
        Snackbar.Add($"File {_uploadedFileName} selected (Demo Mode)", Severity.Info);
    }

    // Helper Class for Chat Summary
    public class ConversationSummary
    {
        public User OtherUser { get; set; } = null!;
        public int? TaskId { get; set; }
        public string LastMessageContent { get; set; } = "";
        public DateTime LastMessageTime { get; set; }
        public int UnreadCount { get; set; }
    }

    // Password Match Validation
    private string PasswordMatch(string arg)
    {
        if (_newPassword != arg)
            return "Passwords do not match";
        return null;
    }



    // Password Change Handler

    private async Task ChangePassword()

    {

        await _passwordForm.Validate();

        if (!_passwordForm.IsValid) return;



        if (_user == null) return;



        var success = await AuthService.ChangePasswordAsync(_user.Id, _currentPassword, _newPassword);



        if (success)

        {

            Snackbar.Add("Password updated successfully!", Severity.Success);



            _currentPassword = "";

            _newPassword = "";

            _confirmPassword = "";



            await _passwordForm.ResetAsync();

        }

        else

        {

            Snackbar.Add("Failed to update password. Check your current password.", Severity.Error);

        }

    }

    private void UploadCertificate(IBrowserFile file)
    {
        _uploadedCertName = file.Name;
        Snackbar.Add($"Certificate {_uploadedCertName} selected", Severity.Info);
    }

    private async Task SubmitVerification()
    {
        _isLoading = true;
        await Task.Delay(1000);
        
        _hasPendingRequest = true;
        _uploadedCertName = null;
        _isLoading = false;
        
        Snackbar.Add("Certificate submitted for review! An admin will check it soon.", Severity.Success);
    }

}