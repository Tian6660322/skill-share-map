@page "/profile"
@page "/profile/{UserId:int}"
@using SkillShareMap.Services
@using SkillShareMap.Models
@inject IAuthService AuthService
@inject ITaskService TaskService
@inject IRatingService RatingService
@inject IWalletService WalletService
@inject IChatService ChatService
@inject NavigationManager Navigation
@inject UserState UserState
@inject ISnackbar Snackbar

<PageTitle>My Profile</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pt-8 px-12 pb-16">
    @if (_isLoading)
    {
        <div class="d-flex justify-center align-center" style="min-height: 400px;">
            <MudProgressCircular Size="Size.Large" Indeterminate="true" />
        </div>
    }
    else if (_user != null)
    {
        <MudGrid Spacing="0">
            <MudItem xs="12" sm="2" Class="pl-md-8">
                <div class="d-flex flex-column gap-2">

                    <div @onclick="@(() => _activeTab = "Profile")"
                         class="@GetSidebarClass("Profile")">
                        <MudImage Src="images/profile_icon.svg" Class="mr-4" Width="24" Height="24" ObjectFit="ObjectFit.Contain" />
                        <MudText Typo="Typo.body1" Style="@GetSidebarTextStyle("Profile")">Profile</MudText>
                    </div>

                    <div @onclick="@(() => _activeTab = "Task")"
                         class="@GetSidebarClass("Task")">
                        <MudImage Src="images/task_icon.svg" Class="mr-4" Width="24" Height="24" ObjectFit="ObjectFit.Contain" />
                        <MudText Typo="Typo.body1" Style="@GetSidebarTextStyle("Task")">Task</MudText>
                    </div>

                    @if (_user.Role == UserRole.Student)
                    {
                        <div @onclick="@(() => _activeTab = "Badges")"
                             class="@GetSidebarClass("Badges")">
                            <MudImage Src="images/badge_icon.svg" Class="mr-4" Width="24" Height="24" ObjectFit="ObjectFit.Contain" />
                            <MudText Typo="Typo.body1" Style="@GetSidebarTextStyle("Badges")">Badges</MudText>
                        </div>
                    }

                    @if (_isCurrentUser)
                    {
                        <div @onclick="@(() => _activeTab = "Wallet")"
                             class="@GetSidebarClass("Wallet")">
                            <MudImage Src="images/wallet_icon.svg" Class="mr-4" Width="24" Height="24" ObjectFit="ObjectFit.Contain" />
                            <MudText Typo="Typo.body1" Style="@GetSidebarTextStyle("Wallet")">Wallet</MudText>
                        </div>

                        <div @onclick="@(() => _activeTab = "Chat")"
                             class="@GetSidebarClass("Chat")">
                            <MudImage Src="images/chat_icon.svg" Class="mr-4" Width="24" Height="24" ObjectFit="ObjectFit.Contain" />
                            <MudText Typo="Typo.body1" Style="@GetSidebarTextStyle("Chat")">Chat</MudText>
                        </div>

                        <div @onclick="@(() => _activeTab = "Setting")"
                             class="@GetSidebarClass("Setting")">
                            <MudIcon Icon="@Icons.Material.Filled.Settings" Class="mr-4" Size="Size.Medium" Style="color: #000000;"/>
                            <MudText Typo="Typo.body1" Style="@GetSidebarTextStyle("Setting")">Setting</MudText>
                        </div>
                    }
                </div>
            </MudItem>

            <MudItem xs="12" sm="9" Class="pl-sm-12">

                @if (_activeTab == "Task")
                {
                     <MudText Typo="Typo.h5" Class="mb-6" Style="font-weight:700; color: #1B1B1B;">Search Recent Task</MudText>

                    <MudPaper Elevation="0" Class="d-flex align-center pa-2 rounded-pill mb-10"
                              Style="background-color: #F3F4F6; width: 100%;">
                        <MudTextField @bind-Value="_searchString" 
                                      Placeholder="Search task" 
                                      Class="flex-grow-1 ml-4 mr-4 hide-idle-line" 
                                      Style="background-color: transparent;" />
                        <MudIconButton Icon="@Icons.Material.Filled.Search" Variant="Variant.Filled" Size="Size.Medium"
                                       Class="rounded-circle" Style="background-color: #4a75b0; color: white; width: 48px; height: 48px;" />
                    </MudPaper>

                    <MudText Typo="Typo.h5" Class="mb-6" Style="font-weight:700; color: #1B1B1B;">My Tasks</MudText>

                    <div class="d-flex gap-4 mb-8">
                        <MudButton Variant="@(_showCreatedTasks ? Variant.Filled : Variant.Outlined)"
                                   OnClick="@(() => _showCreatedTasks = true)"
                                   Style="@(_showCreatedTasks ? "background-color: #2b2b3d; color: white; border-radius: 16px; font-weight: 600; padding: 12px 32px;" : "background-color: white; color: #1B1B1B; border-color: #E0E0E0; border-radius: 16px; font-weight: 600; padding: 12px 32px;")"
                                   DisableElevation="true">Created Tasks</MudButton>

                        <MudButton Variant="@(!_showCreatedTasks ? Variant.Filled : Variant.Outlined)"
                                   OnClick="@(() => _showCreatedTasks = false)"
                                   Style="@(!_showCreatedTasks ? "background-color: #2b2b3d; color: white; border-radius: 16px; font-weight: 600; padding: 12px 32px;" : "background-color: white; color: #1B1B1B; border-color: #E0E0E0; border-radius: 16px; font-weight: 600; padding: 12px 32px;")"
                                   DisableElevation="true">Accepted Tasks</MudButton>
                    </div>

                    <MudPaper Elevation="0" Class="pa-8 rounded-xl" Style="background-color: #F8F9FA; min-height: 400px;">
                        @{ var displayedTasks = GetDisplayedTasks(); }
                        @if (displayedTasks.Any())
                        {
                            @foreach (var task in displayedTasks)
                            {
                                <MudPaper Elevation="0" Class="pa-6 mb-4 rounded-xl d-flex justify-space-between align-center hover-card"
                                          Style="background-color: #FFFFFF; cursor: pointer;"
                                          @onclick="@(() => Navigation.NavigateTo($"/task/{task.Id}"))">
                                    <div>
                                        <div class="d-flex align-center mb-3">
                                            <MudText Typo="Typo.h6" Style="font-weight: 700; color: #1B1B1B; margin-right: 32px;">@task.Title</MudText>
                                            <MudText Typo="Typo.h6" Style="font-weight: 700; color: #1B1B1B;">$@task.Budget</MudText>
                                        </div>
                                        <div class="d-flex align-center mb-2">
                                            <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Style="color: #9E9E9E; margin-right: 8px;" />
                                            <MudText Typo="Typo.caption" Style="color: #9E9E9E; font-size: 13px;">@task.LocationAddress (@task.Category)</MudText>
                                        </div>
                                        <div class="d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" Style="color: #9E9E9E; margin-right: 8px;" />
                                            <MudText Typo="Typo.caption" Style="color: #9E9E9E; font-size: 13px;">
                                                @(task.Deadline.HasValue ? $"Due {task.Deadline.Value.ToString("MMM dd")}" : "No Deadline")
                                            </MudText>
                                        </div>
                                    </div>
                                    <div>
                                        <MudChip T="string" Style="@($"{GetStatusStyle(task.Status)} border-radius: 20px; font-size: 14px;")" Label="true" Class="px-4 py-2 fw-bold">@task.Status</MudChip>
                                    </div>
                                </MudPaper>
                            }
                        }
                        else
                        {
                            <div class="d-flex flex-column align-center justify-center pt-8">
                                <MudIcon Icon="@Icons.Material.Outlined.Assignment" Size="Size.Large" style="color: #BDBDBD;" />
                                <MudText Typo="Typo.body1" Class="mt-4" Style="color: #9E9E9E;">No tasks found.</MudText>
                            </div>
                        }
                    </MudPaper>
                }
                
                else if (_activeTab == "Profile")
                {

                    <MudPaper Elevation="0" Class="pa-6 mb-6 rounded-xl d-flex align-center" Style="border: 1px solid #e0e0e0;">
                        <MudAvatar Style="height: 100px; width: 100px; font-size: 2rem;" Class="mr-6">
                            @if (!string.IsNullOrEmpty(_user.AvatarUrl)) 
                            { 
                                <MudImage Src="@_user.AvatarUrl" /> 
                            }
                            else 
                            { 
                                @_user.Username?.Substring(0, 1).ToUpper()
                            }
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.h5" Style="font-weight: 700; color: #1B1B1B;">@_user.Username</MudText>
                            <MudText Typo="Typo.h6" Style="color: #666;">@_user.Role</MudText>
                            <div class="d-flex align-center mt-1">
                                <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Color="Color.Secondary" Class="mr-1"/>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@(_user.HomeBaseAddress ?? "Location not set")</MudText>
                            </div>
                        </div>
                    </MudPaper>

                    <MudPaper Elevation="0" Class="pa-6 mb-6 rounded-xl" Style="border: 1px solid #e0e0e0;">
                        <div class="d-flex justify-space-between align-center mb-6">
                            <MudText Typo="Typo.h6" Style="font-weight: 700; color: #1B1B1B;">Personal Information</MudText>
                            @if (_isCurrentUser)
                            {
                                <MudButton Variant="@(_isEditingProfile ? Variant.Filled : Variant.Outlined)"
                                           Color="Color.Primary"
                                           Size="Size.Small" 
                                           DisableElevation="true" 
                                           Style="border-radius: 8px;"
                                           OnClick="@ToggleEditProfile">
                                    @(_isEditingProfile ? "Save" : "Edit")
                                </MudButton>
                            }
                        </div>

                        <MudGrid>
                            <MudItem xs="12" md="6">
                                <MudText Typo="Typo.caption" Color="Color.Primary">Username</MudText>
                                @if (_isEditingProfile)
                                {
                                    <MudTextField @bind-Value="_user.Username" 
                                                  Variant="Variant.Outlined" 
                                                  Margin="Margin.Dense"
                                                  HelperText="Log in with the new username next time" />
                                }
                                else
                                {
                                    <MudText Typo="Typo.subtitle2" Class="mt-1" Style="font-weight: 500;"  Color="Color.Secondary">@_user.Username</MudText>
                                }
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <MudText Typo="Typo.caption" Color="Color.Primary">Full Name</MudText>
                                @if (_isEditingProfile)
                                {
                                    <div class="d-flex gap-2">
                                        <MudTextField @bind-Value="_user.FirstName" Label="First Name" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                        <MudTextField @bind-Value="_user.LastName" Label="Last Name" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                    </div>
                                }
                                else
                                {
                                    <MudText Typo="Typo.subtitle2" Class="mt-1" Style="font-weight: 500;" Color="Color.Secondary">@_user.FirstName @_user.LastName</MudText>
                                }
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <MudText Typo="Typo.caption" Color="Color.Primary">Email Address</MudText>
                                @if (_isEditingProfile)
                                {
                                    <MudTextField @bind-Value="_user.Email" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                }
                                else
                                {
                                    <MudText Typo="Typo.subtitle2" Class="mt-1" Style="font-weight: 500;" Color="Color.Secondary">@_user.Email</MudText>
                                }
                            </MudItem>
    
                            <MudItem xs="12" md="6">
                                <MudText Typo="Typo.caption" Color="Color.Primary">User Role</MudText>
                                <MudText Typo="Typo.subtitle2" Class="mt-1" Style="font-weight: 500;" Color="Color.Secondary">@_user.Role</MudText>
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <MudText Typo="Typo.caption" Color="Color.Primary">School / Institution</MudText>
                                @if (_isEditingProfile)
                                {
                                    <MudTextField @bind-Value="_user.SchoolName" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                }
                                else
                                {
                                    <MudText Typo="Typo.subtitle2" Class="mt-1" Style="font-weight: 500;" Color="Color.Secondary">@(_user.SchoolName ?? "N/A")</MudText>
                                }
                            </MudItem>
    
                            <MudItem xs="12" md="6">
                                <MudText Typo="Typo.caption" Color="Color.Primary">Degree / Major</MudText>
                                @if (_isEditingProfile)
                                {
                                    <MudTextField @bind-Value="_user.Degree" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                }
                                else
                                {
                                    <MudText Typo="Typo.subtitle2" Class="mt-1" Style="font-weight: 500;" Color="Color.Secondary">@_user.Degree</MudText>
                                }
                            </MudItem>
                        </MudGrid>
                    </MudPaper>

                     <MudPaper Elevation="0" Class="pa-6 mb-6 rounded-xl" Style="border: 1px solid #e0e0e0;">
                        <div class="d-flex justify-space-between align-center mb-6">
                            <MudText Typo="Typo.h6" Style="font-weight: 700; color: #1B1B1B;">Address</MudText>
                            @if (_isCurrentUser)
                            {
                                <MudButton Variant="@(_isEditingAddress ? Variant.Filled : Variant.Outlined)"
                                           Color="Color.Primary"
                                           Size="Size.Small" 
                                           Style="border-radius: 8px;"
                                           OnClick="@ToggleEditAddress">
                                     @(_isEditingAddress ? "Save" : "Edit")
                                </MudButton>
                            }
                        </div>
                        <MudGrid>
                            <MudItem xs="12">
                                <MudText Typo="Typo.caption" Color="Color.Primary">Full Address</MudText>
                                @if (_isEditingAddress)
                                {
                                     <MudTextField @bind-Value="_user.HomeBaseAddress" 
                                                   Variant="Variant.Outlined" 
                                                   Lines="3" 
                                                   Placeholder="Enter your address here..." />
                                }
                                else
                                {
                                    <MudText Typo="Typo.subtitle2" Class="mt-1" Style="font-weight: 500;" Color="Color.Secondary">
                                        @(_user.HomeBaseAddress ?? "No address provided")
                                    </MudText>
                                }
                            </MudItem>
                        </MudGrid>
                    </MudPaper>

                    <MudPaper Elevation="0" Class="pa-6 mb-6 rounded-xl" Style="border: 1px solid #e0e0e0;">
                         <MudText Typo="Typo.h6" Class="mb-4" Style="font-weight: 700; color: #1B1B1B;">My Skills</MudText>
                         @if (_isCurrentUser)
                         {
                             <MudSelect T="TaskCategory" Label="Select Skills" MultiSelection="true" @bind-SelectedValues="_selectedSkills" Variant="Variant.Outlined" AnchorOrigin="Origin.BottomLeft" TransformOrigin="Origin.TopLeft" Class="my-small-select" PopoverClass="my-dropdown-menu">
                                @foreach (var category in Enum.GetValues<TaskCategory>())
                                {
                                    <MudSelectItem Value="@category">@category</MudSelectItem>
                                }
                             </MudSelect>
                         }
                         
                         <div class="d-flex flex-wrap gap-2 mt-4">
                             @if (_selectedSkills != null && _selectedSkills.Any())
                             {
                                 @foreach (var skill in _selectedSkills)
                                 {
                                     <MudChip T="string" Color="Color.Primary" Variant="Variant.Text">@skill</MudChip>
                                 }
                             }
                             else
                             {
                                 <MudText Typo="Typo.body2" Color="Color.Secondary">No skills selected yet.</MudText>
                             }
                         </div>
                    </MudPaper>

                    <MudPaper Elevation="0" Class="pa-6 mb-6 rounded-xl" Style="border: 1px solid #e0e0e0;">
                        <MudText Typo="Typo.h6" Class="mb-4" Style="font-weight: 700; color: #1B1B1B;">Portfolio / CV</MudText>
                        
                        <MudStack Style="width: 100%">
                            <MudFileUpload T="IBrowserFile" FilesChanged="UploadFiles">
                                <ActivatorContent>
                                    <MudButton Variant="Variant.Filled" 
                                               Color="Color.Primary" 
                                               StartIcon="@Icons.Material.Filled.CloudUpload"
                                               Style="border-radius: 8px;">
                                        Upload Documents
                                    </MudButton>
                                </ActivatorContent>
                            </MudFileUpload>

                            @if (_uploadedFileName != null)
                            {
                                <MudAlert Severity="Severity.Info" Class="mt-2" NoIcon="false">
                                    Uploaded: <strong>@_uploadedFileName</strong>
                                </MudAlert>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">Upload your CV, Portfolio PDF, or other relevant documents here.</MudText>
                            }
                        </MudStack>
                    </MudPaper>
                }

                else if (_activeTab == "Badges")
                {
                    <MudText Typo="Typo.h5" Class="mb-6" Style="font-weight:700; color: #1B1B1B;">My Badges</MudText>
                    
                    @if (_badges.Any())
                    {
                        <MudPaper Elevation="0" Class="pa-8 rounded-xl" Style="background-color: #F8F9FA; min-height: 400px;">
                            <div class="d-flex flex-wrap gap-4">
                                @foreach (var badge in _badges)
                                {
                                    <MudPaper Class="d-flex flex-column align-center pa-4 rounded-xl" Elevation="0" Style="background-color: white; min-width: 150px;">
                                        <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Size="Size.Large" Color="@GetBadgeColor(badge.Tier)" Class="mb-2" />
                                        <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">@GetCategoryName(badge.Category)</MudText>
                                        <MudChip T="string" Color="@GetBadgeColor(badge.Tier)" Size="Size.Small" Class="mt-2">@badge.Tier</MudChip>
                                    </MudPaper>
                                }
                            </div>
                        </MudPaper>
                    }
                    else
                    {
                        <MudPaper Class="pa-8 d-flex flex-column align-center justify-center rounded-xl" Elevation="0" Style="background-color: #F8F9FA; min-height: 400px;">
                            <MudIcon Icon="@Icons.Material.Outlined.EmojiEvents" Size="Size.Large" Color="Color.Default" />
                            <MudText Typo="Typo.body1" Class="mt-4" Color="Color.Secondary">No badges earned yet.</MudText>
                        </MudPaper>
                    }
                }

                else if (_activeTab == "Wallet")
                {
                    <MudText Typo="Typo.h5" Class="mb-6" Style="font-weight:700; color: #1B1B1B;">My Wallet</MudText>

                    @if (_wallet != null)
                    {
                        <MudGrid>
                            <MudItem xs="12" md="6">
                                <MudPaper Elevation="0" Class="pa-6 rounded-xl mb-4" Style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
                                    <MudText Typo="Typo.subtitle2" Class="mb-2" Style="opacity: 0.8;">Available Balance</MudText>
                                    <MudText Typo="Typo.h3" Class="mb-4" Style="font-weight: 700;">$@_wallet.Balance.ToString("N2")</MudText>
                                    <div class="d-flex gap-2">
                                        <MudButton Variant="Variant.Filled" Color="Color.Surface" StartIcon="@Icons.Material.Filled.Add" Size="Size.Small" Class="rounded-lg">Top Up</MudButton>
                                    </div>
                                </MudPaper>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudPaper Elevation="0" Class="pa-6 rounded-xl mb-4" Style="background-color: #F8F9FA;">
                                    <MudText Typo="Typo.subtitle2" Class="mb-2" Color="Color.Secondary">Transactions</MudText>
                                    @if (_walletTransactions.Any())
                                    {
                                        <MudList T="string" Dense="true" DisablePadding="true">
                                            @foreach (var trans in _walletTransactions.Take(3))
                                            {
                                                <MudListItem T="string">
                                                    <div class="d-flex justify-space-between align-center width-100">
                                                        <div>
                                                            <MudText Typo="Typo.body2" Style="font-weight: 600;">@trans.Type</MudText>
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@trans.CreatedAt.ToString("MMM dd")</MudText>
                                                        </div>
                                                        <MudText Typo="Typo.body2" Color="@(trans.Amount > 0 ? Color.Success : Color.Error)" Style="font-weight: 700;">
                                                            @(trans.Amount > 0 ? "+" : "")$@trans.Amount.ToString("N2")
                                                        </MudText>
                                                    </div>
                                                </MudListItem>
                                                <MudDivider />
                                            }
                                        </MudList>
                                        <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true" Href="/wallet" Class="mt-2">View All</MudButton>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">No recent transactions.</MudText>
                                    }
                                </MudPaper>
                            </MudItem>
                        </MudGrid>
                    }
                    else
                    {
                         <MudProgressCircular Indeterminate="true" />
                    }
                }

                else if (_activeTab == "Chat")
                {
                     <MudText Typo="Typo.h5" Class="mb-6" Style="font-weight:700; color: #1B1B1B;">Recent Messages</MudText>
                     
                     <MudPaper Elevation="0" Class="pa-4 rounded-xl" Style="background-color: #F8F9FA; min-height: 400px;">
                        @if (_conversations.Any())
                        {
                            <MudList T="string" Clickable="true">
                                @foreach (var chat in _conversations)
                                {
                                    <MudPaper Elevation="0" Class="mb-2 rounded-lg" Style="background-color: white;">
                                        <MudListItem T="string" OnClick="@(() => Navigation.NavigateTo($"/chat/{chat.OtherUser.Id}?TaskId={chat.TaskId}"))">
                                            <div class="d-flex align-center">
                                                <MudBadge Dot="true" Color="Color.Error" Visible="@(chat.UnreadCount > 0)" Overlap="true" Bordered="true">
                                                    <MudAvatar Color="Color.Primary" Size="Size.Medium">@chat.OtherUser.Username?.Substring(0, 1).ToUpper()</MudAvatar>
                                                </MudBadge>
                                                <div class="ml-4 flex-grow-1">
                                                    <div class="d-flex justify-space-between">
                                                        <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">@chat.OtherUser.Username</MudText>
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@chat.LastMessageTime.ToString("MMM dd")</MudText>
                                                    </div>
                                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 200px;">
                                                        @chat.LastMessageContent
                                                    </MudText>
                                                </div>
                                            </div>
                                        </MudListItem>
                                    </MudPaper>
                                }
                            </MudList>
                        }
                        else
                        {
                            <div class="d-flex flex-column align-center justify-center pt-8">
                                <MudIcon Icon="@Icons.Material.Outlined.ChatBubbleOutline" Size="Size.Large" style="color: #BDBDBD;" />
                                <MudText Typo="Typo.body1" Class="mt-4" Style="color: #9E9E9E;">No messages yet.</MudText>
                            </div>
                        }
                     </MudPaper>
                }

                else if (_activeTab == "Setting")
                {
                    <MudText Typo="Typo.h5" Class="mb-6" Style="font-weight:700; color: #1B1B1B;">Security Settings</MudText>

                    <MudPaper Elevation="0" Class="pa-8 rounded-xl" Style="border: 1px solid #e0e0e0; max-width: 600px;">
                        <MudText Typo="Typo.h6" Class="mb-4" Style="font-weight: 700;">Change Password</MudText>
        
                        <MudForm @ref="_passwordForm">
                            <MudTextField T="string" Label="Current Password" 
                                          InputType="InputType.Password"
                                          Variant="Variant.Outlined" 
                                          Class="mb-4"
                                          @bind-Value="_currentPassword"
                                          Required="true"
                                          RequiredError="Current password is required"/>

                            <MudTextField T="string" Label="New Password" 
                                          InputType="InputType.Password"
                                          Variant="Variant.Outlined" 
                                          Class="mb-4"
                                          @bind-Value="_newPassword"
                                          Required="true"
                                          RequiredError="New password is required"/>

                            <MudTextField T="string" Label="Confirm New Password" 
                                          InputType="InputType.Password"
                                          Variant="Variant.Outlined" 
                                          Class="mb-6"
                                          @bind-Value="_confirmPassword"
                                          Required="true"
                                          Validation="@(new Func<string, string>(PasswordMatch))"/>

                            <MudButton Variant="Variant.Filled" 
                                       Color="Color.Primary" 
                                       Size="Size.Large"
                                       OnClick="ChangePassword"
                                       DisableElevation="true"
                                       Style="border-radius: 8px;">
                                Update Password
                            </MudButton>
                        </MudForm>
                    </MudPaper>


                    <MudPaper Elevation="0" Class="pa-8 mt-6 rounded-xl" Style="border: 1px solid #e0e0e0; max-width: 600px;">
                        <MudText Typo="Typo.h6" Class="mb-4" Style="font-weight: 700;">Identity & Certificates</MudText>
                        
                        <MudText Typo="Typo.body2" Class="mb-4" Color="Color.Secondary">
                            Upload your professional certificates or student ID to get the "Verified" badge.
                        </MudText>

                        <div class="d-flex align-center mb-6">
                            <MudText Typo="Typo.subtitle2" Class="mr-2">Current Status:</MudText>
                            @if (_isVerified)
                            {
                                <MudChip T="string" Color="Color.Success" Size="Size.Small" Icon="@Icons.Material.Filled.CheckCircle">Verified</MudChip>
                            }
                            else if (_hasPendingRequest)
                            {
                                <MudChip T="string" Color="Color.Warning" Size="Size.Small" Icon="@Icons.Material.Filled.HourglassEmpty">Pending Review</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Color="Color.Default" Size="Size.Small">Unverified</MudChip>
                            }
                        </div>

                        <MudStack Style="width: 100%">
                            <MudFileUpload T="IBrowserFile" FilesChanged="UploadCertificate">
                                <ActivatorContent>
                                    <MudButton Variant="Variant.Filled" 
                                               Color="Color.Secondary" 
                                               StartIcon="@Icons.Material.Filled.CloudUpload"
                                               Style="border-radius: 8px;"
                                               Disabled="@(_isVerified || _hasPendingRequest)">
                                        @(_hasPendingRequest ? "Processing..." : "Upload Certificate (PDF/JPG)")
                                    </MudButton>
                                </ActivatorContent>
                            </MudFileUpload>

                            @if (_uploadedCertName != null)
                            {
                                <MudAlert Severity="Severity.Info" Class="mt-2" NoIcon="false">
                                    File selected: <strong>@_uploadedCertName</strong>
                                    <br/>
                                    <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" OnClick="SubmitVerification">Submit for Review</MudButton>
                                </MudAlert>
                            }
                        </MudStack>
                    </MudPaper>
                }

            </MudItem>
        </MudGrid>
    }
    else
    {
        <MudAlert Severity="Severity.Error">User not found</MudAlert>
    }
</MudContainer>

