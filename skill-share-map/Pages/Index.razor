@page "/"
@using SkillShareMap.Services
@using SkillShareMap.Models
@using SkillShareMap.Shared.Components
@inject ITaskService TaskService
@inject IJobService JobService
@inject IGeoService GeoService
@inject UserState UserState
@inject NavigationManager Navigation

<PageTitle>Skill Share Map</PageTitle>

<div style="width: 100%; 
            position: relative;
            background-color: #FFFFFF;">

    <div style="position: absolute; 
                bottom: -150px;
                left: 50%; 
                transform: translateX(-50%); 
                width: 600px; 
                height: 300px; 
                background: radial-gradient(ellipse at center, rgba(74, 117, 176, 0.25) 0%, transparent 70%);
                filter: blur(60px);
                z-index: 0;
                pointer-events: none;"> 
    </div>

    <MudContainer MaxWidth="MaxWidth.Large" Class="pt-12 pb-20" Style="position: relative; z-index: 1;">
        <MudStack AlignItems="AlignItems.Center" Spacing="2" Class="text-center">
            <MudText Typo="Typo.h3" Align="Align.Center" Color="Color.Secondary" Style="font-weight: 700;">
                Get Paid <br /> For What You Know
            </MudText>

            <MudText Typo="Typo.subtitle1" Align="Align.Center" Color="Color.Secondary" Class="mt-2">
                Explore the campus map <br /> click on a task <br /> and start earning
            </MudText>
            
            <MudButton Variant="Variant.Filled" 
                       Color="Color.Dark" 
                       Size="Size.Large" 
                       Class="mt-8 rounded-pill px-8 py-2"
                       Style="background-color: #2b2b3d; color: white; box-shadow: 0 4px 15px rgba(0,0,0,0.15);">
                Post a Task Now
            </MudButton>
        </MudStack>
    </MudContainer>

</div> <MudContainer MaxWidth="MaxWidth.Large" Class="my-12" Style="position: relative; z-index: 2; width: 80%; max-width: 1400px; margin: 0 auto;">
    
    <MudPaper Elevation="4" Class="rounded-xl overflow-hidden" Style="height: 650px; border: 1px solid #e0e0e0;">
        <MudGrid Spacing="0" Style="height: 100%;">
            
            <MudItem xs="12" md="3" Style="height: 100%; background-color: #1a1b1e; overflow-y: auto;">
                <MudPaper Elevation="0" Class="pa-6" Style="background-color: transparent; color: white;">
                    <MudText Typo="Typo.h6" Class="mb-6" Style="font-weight: bold;">Filter</MudText>

                    <MudText Typo="Typo.subtitle2" Class="mb-2" Style="color: #FFFFFF; font-weight: bold;">Display Type</MudText>
                    <MudRadioGroup T="string" 
                                   Value="_displayType" 
                                   ValueChanged="OnDisplayTypeChanged">
                        <MudRadio T="string" Value="@("tasks")" Color="Color.Primary" Class="mr-3" Style="color: white;">Tasks</MudRadio>
                        <MudRadio T="string" Value="@("jobs")" Color="Color.Primary" Class="mr-3" Style="color: white;">Jobs</MudRadio>
                    </MudRadioGroup>

                    <MudDivider Class="my-4" Style="background-color: #404040;" />

                    @if (_displayType == "tasks")
                    {
                        <MudText Typo="Typo.subtitle2" Class="mb-2" Style="color: #FFFFFF; font-weight: bold;">Category</MudText>
                        <MudSelect T="TaskCategory?"
                                   MultiSelection="true" 
                                   @bind-SelectedValues="_selectedCategories"
                                   Placeholder="Select Categories"
                                   Clearable="true"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Class="mb-4 white-placeholder glow-focus" 
                                   PopoverClass="fancy-menu"
                                   Style="background-color: #2c2d30; color: white;"
                                   AdornmentColor="Color.Default">
                            @foreach (var category in Enum.GetValues<TaskCategory>())
                            {
                                <MudSelectItem T="TaskCategory?" Value="@((TaskCategory?)category)">
                                    @GetCategoryName(category)
                                </MudSelectItem>
                            }
                        </MudSelect>

                        <MudText Typo="Typo.subtitle2" Class="mb-2" Style="color: #FFFFFF; font-weight: bold;">Status</MudText>
                        <MudSelect T="SkillTaskStatus?"
                                   MultiSelection="true"
                                   @bind-SelectedValues="_selectedStatuses"
                                   Placeholder="Select Statuses"
                                   Clearable="true"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Class="mb-4 white-placeholder glow-focus"
                                   PopoverClass="fancy-menu"
                                   Style="background-color: #2c2d30; color: white;"
                                   AdornmentColor="Color.Default">
                            <MudSelectItem T="SkillTaskStatus?" Value="@((SkillTaskStatus?)SkillTaskStatus.Open)">Open</MudSelectItem>
                            <MudSelectItem T="SkillTaskStatus?" Value="@((SkillTaskStatus?)SkillTaskStatus.Assigned)">Assigned</MudSelectItem>
                            <MudSelectItem T="SkillTaskStatus?" Value="@((SkillTaskStatus?)SkillTaskStatus.PendingCompletion)">In Progress</MudSelectItem>
                        </MudSelect>

                        <MudText Typo="Typo.subtitle2" Class="mt-6 mb-2" Style="color: #FFFFFF;">Distance: @_distanceKm km</MudText>
                        <MudSlider T="int"
                                   Value="_distanceKm"
                                   ValueChanged="OnDistanceChanged"
                                   Min="0"
                                   Max="50"
                                   Step="1"
                                   Color="Color.Primary"
                                   Immediate="false" />
                        <MudText Typo="Typo.caption" Class="mt-1" Style="color: #e0e0e0;">
                            Showing @_visibleTasks.Count task(s) within @_distanceKm km
                        </MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.subtitle2" Class="mb-2" Style="color: #a0a0a0;">Distance: @_distanceKm km</MudText>
                        <MudSlider T="int"
                                   Value="_distanceKm"
                                   ValueChanged="OnDistanceChanged"
                                   Min="0"
                                   Max="50"
                                   Step="1"
                                   Color="Color.Primary"
                                   Immediate="false" />
                        <MudText Typo="Typo.caption" Class="mt-1" Style="color: #e0e0e0;">
                            Showing @_visibleJobs.Count job(s) within @_distanceKm km
                        </MudText>
                    }

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               Class="mt-8 py-2"
                               Style="background-color: #7da0fa; color: #000; font-weight: bold;"
                               OnClick="ApplyFilters">
                        Apply Filters
                    </MudButton>

                    <MudButton Variant="Variant.Text"
                               FullWidth="true"
                               Class="mt-2"
                               Style="color: #a0a0a0;"
                               OnClick="ResetFilters">
                        Reset
                    </MudButton>

                    @if (!string.IsNullOrEmpty(_noResultsMessage))
                    {
                        <MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="mt-3" Style="color: white;">
                            @_noResultsMessage
                        </MudAlert>
                    }
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="9" Style="height: 100%; position: relative;">
                <MapComponent @ref="_mapComponent"
                              OnMarkerClick="HandleMarkerClick"
                              MapId="mainMap"
                              Height="100%"
                              InitialLat="@_userLat"
                              InitialLng="@_userLng"
                              InitialZoom="13" />

                @if (_selectedTask != null)
                {
                    <MudPaper Elevation="8" Class="pa-4 mx-4 mb-4 rounded-lg"
                              Style="position: absolute; bottom: 0; left: 0; right: 0; max-height: 40%; overflow-y: auto; z-index: 1000;">
                        <div class="d-flex justify-space-between align-center mb-3">
                            <MudText Typo="Typo.h6">@_selectedTask.Title</MudText>
                            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="() => _selectedTask = null" />
                        </div>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4" Href="@($"/task/{_selectedTask.Id}")">View Details</MudButton>
                    </MudPaper>
                }

                @if (_selectedJob != null)
                {
                    <MudPaper Elevation="8" Class="pa-4 mx-4 mb-4 rounded-lg"
                              Style="position: absolute; bottom: 0; left: 0; right: 0; max-height: 40%; overflow-y: auto; z-index: 1000;">
                        <div class="d-flex justify-space-between align-center mb-3">
                            <MudText Typo="Typo.h6">@_selectedJob.Title</MudText>
                            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="() => _selectedJob = null" />
                        </div>
                        <MudButton Variant="Variant.Filled" Color="Color.Secondary" Class="mt-4" Href="@($"/job/{_selectedJob.Id}")">View Details</MudButton>
                    </MudPaper>
                }
            </MudItem>
        </MudGrid>
    </MudPaper>
    
</MudContainer>

@implements IDisposable

@code {
    private MapComponent? _mapComponent;
    private string _displayType = "tasks";
    private IEnumerable<TaskCategory?> _selectedCategories = new HashSet<TaskCategory?>();
    private IEnumerable<SkillTaskStatus?> _selectedStatuses = new HashSet<SkillTaskStatus?>();
    private int _distanceKm = 50; 

    private SkillTask? _selectedTask;
    private Job? _selectedJob;

    private List<SkillTask> _tasks = new();
    private List<Job> _jobs = new();
    private List<SkillTask> _visibleTasks = new();
    private List<Job> _visibleJobs = new();
    private string? _noResultsMessage;

    private double _userLat = -33.8688;
    private double _userLng = 151.2093;

    protected override async Task OnInitializedAsync()
    {
        Navigation.LocationChanged += OnLocationChanged;

        if (UserState.IsAuthenticated && UserState.CurrentUser != null)
        {
            var currentUser = UserState.CurrentUser;
            if (currentUser.HomeBaseLatitude.HasValue && currentUser.HomeBaseLongitude.HasValue)
            {
                _userLat = currentUser.HomeBaseLatitude.Value;
                _userLng = currentUser.HomeBaseLongitude.Value;
            }
        }

        await LoadData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(500);
            await ApplyFilters();
        }
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        if (e.Location.EndsWith("/") || e.Location.EndsWith("/index"))
        {
            InvokeAsync(async () =>
            {
                await LoadData();
                await ApplyFilters();
            });
        }
    }

    private async Task LoadData()
    {
        _tasks = await TaskService.GetTasksAsync();
        _jobs = await JobService.GetOpenJobsAsync();
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private async Task ApplyFilters()
    {
        if (_mapComponent == null) return;

        await _mapComponent.ClearMarkersAsync();

        _noResultsMessage = null;
        var hasMarkers = false;

        if (_displayType == "tasks")
        {
            _visibleJobs.Clear();

            var filteredTasks = _tasks
                .Where(t => t.Status != SkillTaskStatus.Cancelled && t.Status != SkillTaskStatus.Completed)
                .Where(t => !_selectedCategories.Any() || _selectedCategories.Contains(t.Category))
                .Where(t => !_selectedStatuses.Any() || _selectedStatuses.Contains(t.Status))
                .Where(t => t.Latitude.HasValue && t.Longitude.HasValue)
                .Where(t =>
                {
                    var distance = GeoService.CalculateDistance(
                        _userLat, _userLng,
                        t.Latitude!.Value, t.Longitude!.Value);
                    return distance <= _distanceKm;
                })
                .ToList();

            _visibleTasks = filteredTasks;

            foreach (var task in _visibleTasks)
            {
                await _mapComponent.AddMarkerAsync(
                    task.Id,
                    task.Latitude!.Value,
                    task.Longitude!.Value,
                    task.Title,
                    "task");
                hasMarkers = true;
            }

            if (_visibleTasks.Count == 0)
            {
                _noResultsMessage = $"No tasks found within {_distanceKm} km of your location.";
            }
            else if (_selectedTask != null && !_visibleTasks.Any(t => t.Id == _selectedTask.Id))
            {
                _selectedTask = null;
            }
        }
        else // jobs
        {
            _visibleTasks.Clear();

            var filteredJobs = _jobs
                .Where(j => j.Latitude.HasValue && j.Longitude.HasValue)
                .Where(j =>
                {
                    var distance = GeoService.CalculateDistance(
                        _userLat, _userLng,
                        j.Latitude!.Value, j.Longitude!.Value);
                    return distance <= _distanceKm;
                })
                .ToList();

            _visibleJobs = filteredJobs;

            foreach (var job in _visibleJobs)
            {
                await _mapComponent.AddMarkerAsync(
                    job.Id,
                    job.Latitude!.Value,
                    job.Longitude!.Value,
                    job.Title,
                    "job");
                hasMarkers = true;
            }

            if (_visibleJobs.Count == 0)
            {
                _noResultsMessage = $"No jobs found within {_distanceKm} km of your location.";
            }
            else if (_selectedJob != null && !_visibleJobs.Any(j => j.Id == _selectedJob.Id))
            {
                _selectedJob = null;
            }
        }

        if (hasMarkers)
        {
            await _mapComponent.FitBoundsAsync();
        }
        else
        {
            await _mapComponent.SetViewAsync(_userLat, _userLng, 13);
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task OnDistanceChanged(int value)
    {
        if (_distanceKm == value)
            return;

        _distanceKm = value;
        await ApplyFilters();
    }

    private async Task ResetFilters()
    {
        // 清空集合
        _selectedCategories = new HashSet<TaskCategory?>();
        _selectedStatuses = new HashSet<SkillTaskStatus?>();
    
        _distanceKm = 50; 
        _selectedTask = null;
        _selectedJob = null;
        _noResultsMessage = null;
        await ApplyFilters();
    }

    private string GetCategoryName(TaskCategory category)
    {
        return category switch
        {
            TaskCategory.StudyHelp => "Study Help",
            TaskCategory.TechHelp => "Tech Help",
            TaskCategory.CreativeDesign => "Creative Design",
            TaskCategory.PhotoVideo => "Photo & Video",
            TaskCategory.WritingEditing => "Writing & Editing",
            TaskCategory.LanguageHelp => "Language Help",
            _ => category.ToString()
        };
    }

    private Color GetStatusColor(SkillTaskStatus status)
    {
        return status switch
        {
            SkillTaskStatus.Open => Color.Success,
            SkillTaskStatus.Assigned => Color.Info,
            SkillTaskStatus.PendingDeposit => Color.Warning,
            SkillTaskStatus.PendingCompletion => Color.Warning,
            SkillTaskStatus.Completed => Color.Success,
            SkillTaskStatus.Cancelled => Color.Error,
            _ => Color.Default
        };
    }

    private Task HandleMarkerClick(int markerId)
    {
        if (_displayType == "tasks")
        {
            _selectedTask = _tasks.FirstOrDefault(t => t.Id == markerId);
            _selectedJob = null;
        }
        else
        {
            _selectedJob = _jobs.FirstOrDefault(j => j.Id == markerId);
            _selectedTask = null;
        }

        return InvokeAsync(StateHasChanged);
    }

    private async Task OnDisplayTypeChanged(string type)
    {
        _displayType = type;
        _selectedTask = null;
        _selectedJob = null;
        await ApplyFilters(); 
    }
}

<style>
    /* placeholder */
    .white-placeholder .mud-input-slot {
        font-size: 12px !important;
        padding-top: 2px; /* position */
        color: #ffffff !important;
    }

    .white-placeholder .mud-input-slot::placeholder {
        color: #e0e0e0 !important;
        opacity: 1 !important;
    }
    
    .white-placeholder input::-webkit-input-placeholder {
        color: #e0e0e0 !important;
        opacity: 1 !important;
    }

    /* Multi Choice */
    /* 1. Glowing border effect when input box is focused */
    .glow-focus.mud-input-control-focused .mud-input-outlined-border {
        border-color: #4a75b0 !important;
        box-shadow: 0 0 10px rgba(138, 43, 226, 0.6); /* glow */
    }

    /* 2. Background of the dropdown menu */
    .mud-popover.fancy-menu .mud-list {
        background-color: #ffffff !important; /* 菜单白底，看着干净 */
        padding: 8px;
    }

    /* 3. Style for each option */
    .mud-popover.fancy-menu .mud-list-item {
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        margin-bottom: 6px;
        color: #333 !important;
        transition: all 0.2s;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 12px !important;
    }

    /* 4. Hide built in checkbox */
    .mud-popover.fancy-menu .mud-checkbox {
        display: none !important;
    }

    /* 5. Selected state */
    .mud-popover.fancy-menu .mud-selected-item {
        background-color: #4a75b0 !important;
        color: white !important;
        border-color: #4a75b0;
    }

    .mud-popover.fancy-menu .mud-selected-item:hover {
        background-color: #4a75b0 !important;
    }

    /* 6. Add a ✓ on the right when selected */
    .mud-popover.fancy-menu .mud-selected-item::after {
        content: "✓";
        font-weight: bold;
        font-size: 16px;
        color: white;
        margin-right: 10px;
    }
    
    /* Hover effect for unselected items */
    .mud-popover.fancy-menu .mud-list-item:not(.mud-selected-item):hover {
        background-color: #f5f5f5 !important;
    }

    .white-placeholder .mud-input-slot { font-size: 12px !important; }
    .white-placeholder .mud-input-slot::placeholder { color: #e0e0e0 !important; opacity: 1 !important; }
    .white-placeholder input::-webkit-input-placeholder { color: #e0e0e0 !important; opacity: 1 !important; }
</style>