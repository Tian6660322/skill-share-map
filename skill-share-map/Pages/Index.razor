@page "/"
@using SkillShareMap.Services
@using SkillShareMap.Models
@using SkillShareMap.Shared.Components
@inject ITaskService TaskService
@inject IJobService JobService
@inject IGeoService GeoService
@inject UserState UserState
@inject NavigationManager Navigation

<PageTitle>Skill Share Map</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="pa-0" Style="height: calc(100vh - 64px);">
    <MudGrid Spacing="0" Style="height: 100%;">
        <!-- Left Sidebar - Filters -->
        <MudItem xs="12" md="3" Style="height: 100%; overflow-y: auto; border-right: 1px solid #e0e0e0;">
            <MudPaper Elevation="0" Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-4">Filters</MudText>

                <!-- Type Filter -->
                <MudText Typo="Typo.subtitle2" Class="mb-2">Display Type</MudText>
                <MudRadioGroup @bind-Value="_displayType" T="string">
                    <MudRadio T="string" Value="@("tasks")" Color="Color.Primary">Tasks</MudRadio>
                    <MudRadio T="string" Value="@("jobs")" Color="Color.Secondary">Jobs</MudRadio>
                </MudRadioGroup>

                <MudDivider Class="my-4" />

                @if (_displayType == "tasks")
                {
                    <!-- Category Filter -->
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Category</MudText>
                    <MudSelect @bind-Value="_selectedCategory" T="TaskCategory?" Placeholder="All Categories" Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                        @foreach (var category in Enum.GetValues<TaskCategory>())
                        {
                            <MudSelectItem Value="@((TaskCategory?)category)">@GetCategoryName(category)</MudSelectItem>
                        }
                    </MudSelect>

                    <!-- Status Filter -->
                    <MudText Typo="Typo.subtitle2" Class="mt-4 mb-2">Status</MudText>
                    <MudSelect @bind-Value="_selectedStatus" T="SkillTaskStatus?" Placeholder="All Statuses" Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                        <MudSelectItem Value="@((SkillTaskStatus?)SkillTaskStatus.Open)">Open</MudSelectItem>
                        <MudSelectItem Value="@((SkillTaskStatus?)SkillTaskStatus.Assigned)">Assigned</MudSelectItem>
                        <MudSelectItem Value="@((SkillTaskStatus?)SkillTaskStatus.PendingCompletion)">In Progress</MudSelectItem>
                    </MudSelect>

                    <!-- Distance Filter -->
                    <MudText Typo="Typo.subtitle2" Class="mt-4 mb-2">Distance: @_distanceKm km</MudText>
                    <MudSlider @bind-Value="_distanceKm" Min="1" Max="50" Step="1" Color="Color.Primary" />
                }
                else
                {
                    <!-- Distance Filter for Jobs -->
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Distance: @_distanceKm km</MudText>
                    <MudSlider @bind-Value="_distanceKm" Min="1" Max="50" Step="1" Color="Color.Secondary" />

                    <MudText Typo="Typo.body2" Class="mt-4" Color="Color.Secondary">
                        Showing open job positions within @_distanceKm km
                    </MudText>
                }

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Class="mt-6"
                           OnClick="ApplyFilters">
                    Apply Filters
                </MudButton>

                <MudButton Variant="Variant.Text"
                           FullWidth="true"
                           Class="mt-2"
                           OnClick="ResetFilters">
                    Reset
                </MudButton>
            </MudPaper>
        </MudItem>

        <!-- Main Map Area -->
        <MudItem xs="12" md="9" Style="height: 100%; position: relative;">
            <MapComponent @ref="_mapComponent"
                          OnMarkerClick="HandleMarkerClick"
                          MapId="mainMap"
                          Height="100%"
                          InitialLat="@_userLat"
                          InitialLng="@_userLng"
                          InitialZoom="13" />

            <!-- Task Summary Card (Slides up when item clicked) -->
            @if (_selectedTask != null)
            {
                <MudPaper Elevation="8"
                          Class="pa-4"
                          Style="position: absolute; bottom: 0; left: 0; right: 0; max-height: 40%; overflow-y: auto; z-index: 1000;">
                    <div class="d-flex justify-space-between align-center mb-3">
                        <MudText Typo="Typo.h6">@_selectedTask.Title</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Close"
                                       Size="Size.Small"
                                       OnClick="() => _selectedTask = null" />
                    </div>

                    @if (!string.IsNullOrEmpty(_selectedTask.ImageUrl))
                    {
                        <MudImage Src="@_selectedTask.ImageUrl"
                                  Alt="@_selectedTask.Title"
                                  Height="150"
                                  ObjectFit="ObjectFit.Cover"
                                  Class="rounded mb-3"
                                  Style="width: 100%;" />
                    }

                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudText Typo="Typo.body2">
                                <strong>Posted by:</strong> @_selectedTask.Creator?.Username
                            </MudText>
                            <MudText Typo="Typo.body2">
                                <strong>Location:</strong> @_selectedTask.LocationAddress
                            </MudText>
                            <MudText Typo="Typo.body2">
                                <strong>Budget:</strong> $@_selectedTask.Budget
                            </MudText>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudText Typo="Typo.body2">
                                <strong>Status:</strong>
                                <MudChip T="string" Size="Size.Small" Color="GetStatusColor(_selectedTask.Status)">
                                    @_selectedTask.Status
                                </MudChip>
                            </MudText>
                            <MudText Typo="Typo.body2">
                                <strong>Category:</strong>
                                <CategoryIcon Category="_selectedTask.Category" IconSize="Size.Small" />
                                @GetCategoryName(_selectedTask.Category)
                            </MudText>
                        </MudItem>
                    </MudGrid>

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Class="mt-4"
                               Href="@($"/task/{_selectedTask.Id}")">
                        View Details
                    </MudButton>
                </MudPaper>
            }

            @if (_selectedJob != null)
            {
                <MudPaper Elevation="8"
                          Class="pa-4"
                          Style="position: absolute; bottom: 0; left: 0; right: 0; max-height: 40%; overflow-y: auto; z-index: 1000;">
                    <div class="d-flex justify-space-between align-center mb-3">
                        <MudText Typo="Typo.h6">@_selectedJob.Title</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Close"
                                       Size="Size.Small"
                                       OnClick="() => _selectedJob = null" />
                    </div>

                    <MudText Typo="Typo.body2">
                        <strong>Company:</strong> @_selectedJob.PostedBy?.CompanyName
                    </MudText>
                    <MudText Typo="Typo.body2">
                        <strong>Type:</strong> @_selectedJob.EmploymentType
                    </MudText>
                    <MudText Typo="Typo.body2">
                        <strong>Location:</strong> @_selectedJob.LocationAddress
                    </MudText>

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Secondary"
                               Class="mt-4"
                               Href="@($"/job/{_selectedJob.Id}")">
                        View Details
                    </MudButton>
                </MudPaper>
            }
        </MudItem>
    </MudGrid>
</MudContainer>

@implements IDisposable

@code {
    private MapComponent? _mapComponent;
    private string _displayType = "tasks";
    private TaskCategory? _selectedCategory;
    private SkillTaskStatus? _selectedStatus;
    private int _distanceKm = 50; // Default to 50km to show more tasks

    private SkillTask? _selectedTask;
    private Job? _selectedJob;

    private List<SkillTask> _tasks = new();
    private List<Job> _jobs = new();

    // User's current location (default: Sydney CBD)
    private double _userLat = -33.8688;
    private double _userLng = 151.2093;

    protected override async Task OnInitializedAsync()
    {
        // Subscribe to navigation events to reload data when returning to this page
        Navigation.LocationChanged += OnLocationChanged;

        // Use user's homebase location if available
        if (UserState.IsAuthenticated && UserState.CurrentUser != null)
        {
            var currentUser = UserState.CurrentUser;
            if (currentUser.HomeBaseLatitude.HasValue && currentUser.HomeBaseLongitude.HasValue)
            {
                _userLat = currentUser.HomeBaseLatitude.Value;
                _userLng = currentUser.HomeBaseLongitude.Value;
            }
        }

        await LoadData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(500); // Wait for map to initialize
            await ApplyFilters();
        }
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        // Reload data when navigating back to this page
        if (e.Location.EndsWith("/") || e.Location.EndsWith("/index"))
        {
            InvokeAsync(async () =>
            {
                await LoadData();
                await ApplyFilters();
            });
        }
    }

    private async Task LoadData()
    {
        _tasks = await TaskService.GetTasksAsync();
        _jobs = await JobService.GetOpenJobsAsync();
    }

    public void Dispose()
    {
        // Unsubscribe from navigation events
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private async Task ApplyFilters()
    {
        if (_mapComponent == null) return;

        await _mapComponent.ClearMarkersAsync();

        if (_displayType == "tasks")
        {
            var filteredTasks = _tasks.AsEnumerable();

            // Exclude cancelled tasks by default
            filteredTasks = filteredTasks.Where(t => t.Status != SkillTaskStatus.Cancelled);

            // Filter by category
            if (_selectedCategory.HasValue)
            {
                filteredTasks = filteredTasks.Where(t => t.Category == _selectedCategory.Value);
            }

            // Filter by status
            if (_selectedStatus.HasValue)
            {
                filteredTasks = filteredTasks.Where(t => t.Status == _selectedStatus.Value);
            }

            // Filter by distance
            filteredTasks = filteredTasks.Where(t =>
            {
                if (!t.Latitude.HasValue || !t.Longitude.HasValue)
                    return false;

                var distance = GeoService.CalculateDistance(
                    _userLat, _userLng,
                    t.Latitude.Value, t.Longitude.Value
                );

                return distance <= _distanceKm;
            });

            // Add markers for filtered tasks
            foreach (var task in filteredTasks)
            {
                if (task.Latitude.HasValue && task.Longitude.HasValue)
                {
                    await _mapComponent.AddMarkerAsync(
                        task.Id,
                        task.Latitude.Value,
                        task.Longitude.Value,
                        task.Title,
                        "task"
                    );
                }
            }
        }
        else // jobs
        {
            // Filter jobs by distance
            var filteredJobs = _jobs.Where(j =>
            {
                if (!j.Latitude.HasValue || !j.Longitude.HasValue)
                    return false;

                var distance = GeoService.CalculateDistance(
                    _userLat, _userLng,
                    j.Latitude.Value, j.Longitude.Value
                );

                return distance <= _distanceKm;
            });

            foreach (var job in filteredJobs)
            {
                if (job.Latitude.HasValue && job.Longitude.HasValue)
                {
                    await _mapComponent.AddMarkerAsync(
                        job.Id,
                        job.Latitude.Value,
                        job.Longitude.Value,
                        job.Title,
                        "job"
                    );
                }
            }
        }

        await _mapComponent.FitBoundsAsync();
    }

    private async Task ResetFilters()
    {
        _selectedCategory = null;
        _selectedStatus = null;
        _distanceKm = 50; // Increase to 50km to surface more tasks after clearing filters
        _selectedTask = null;
        _selectedJob = null;
        await ApplyFilters();
    }

    private string GetCategoryName(TaskCategory category)
    {
        return category switch
        {
            TaskCategory.StudyHelp => "Study Help",
            TaskCategory.TechHelp => "Tech Help",
            TaskCategory.CreativeDesign => "Creative Design",
            TaskCategory.PhotoVideo => "Photo & Video",
            TaskCategory.WritingEditing => "Writing & Editing",
            TaskCategory.LanguageHelp => "Language Help",
            _ => category.ToString()
        };
    }

    private Color GetStatusColor(SkillTaskStatus status)
    {
        return status switch
        {
            SkillTaskStatus.Open => Color.Success,
            SkillTaskStatus.Assigned => Color.Info,
            SkillTaskStatus.PendingDeposit => Color.Warning,
            SkillTaskStatus.PendingCompletion => Color.Warning,
            SkillTaskStatus.Completed => Color.Success,
            SkillTaskStatus.Cancelled => Color.Error,
            _ => Color.Default
        };
    }

    private Task HandleMarkerClick(int markerId)
    {
        if (_displayType == "tasks")
        {
            _selectedTask = _tasks.FirstOrDefault(t => t.Id == markerId);
            _selectedJob = null;
        }
        else
        {
            _selectedJob = _jobs.FirstOrDefault(j => j.Id == markerId);
            _selectedTask = null;
        }

        return InvokeAsync(StateHasChanged);
    }
}
