@page "/task/{TaskId:int}"
@using SkillShareMap.Services
@using SkillShareMap.Models
@using SkillShareMap.Shared.Components
@inject ITaskService TaskService
@inject IWalletService WalletService
@inject IRatingService RatingService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject UserState UserState

<PageTitle>Task Details</PageTitle>

@if (_task == null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="py-6">
        <MudGrid>
            <!-- Main Content -->
            <MudItem xs="12" md="8">
                <MudPaper Elevation="2" Class="pa-6">
                    <!-- Task Image -->
                    @if (!string.IsNullOrEmpty(_task.ImageUrl))
                    {
                        <MudImage Src="@_task.ImageUrl"
                                  Alt="@_task.Title"
                                  Height="300"
                                  ObjectFit="ObjectFit.Cover"
                                  Class="rounded mb-4"
                                  Style="width: 100%;" />
                    }

                    <!-- Header -->
                    <div class="d-flex justify-space-between align-center mb-4">
                        <div>
                            <MudText Typo="Typo.h4" GutterBottom="true">@_task.Title</MudText>
                            <MudChip T="string" Color="GetStatusColor(_task.Status)" Size="Size.Small">
                                @_task.Status
                            </MudChip>
                        </div>
                        <CategoryIcon Category="_task.Category" IconSize="Size.Large" />
                    </div>

                    <MudDivider Class="my-4" />

                    <!-- Posted By -->
                    <MudText Typo="Typo.subtitle1" Class="mb-2">
                        <strong>Posted by:</strong>
                    </MudText>
                    <div class="d-flex align-center mb-4">
                        <MudAvatar Color="Color.Primary" Class="mr-2">
                            @_task.Creator?.Username?.Substring(0, 1).ToUpper()
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.body1">@_task.Creator?.Username</MudText>
                            @if (_task.Creator != null)
                            {
                                <StarRating Rating="_task.Creator.ReputationLevel" ShowRating="true" />
                            }
                        </div>
                    </div>

                    <!-- Details -->
                    <MudText Typo="Typo.subtitle1" Class="mb-2"><strong>Category:</strong></MudText>
                    <MudText Typo="Typo.body1" Class="mb-4">
                        <CategoryIcon Category="_task.Category" IconSize="Size.Small" />
                        @GetCategoryName(_task.Category)
                    </MudText>

                    <MudText Typo="Typo.subtitle1" Class="mb-2">
                        <strong>@(_task.NegotiatedPrice.HasValue ? "Negotiated Price:" : "Budget:")</strong>
                    </MudText>
                    <MudText Typo="Typo.h5" Class="mb-4" Color="Color.Success">
                        $@(_task.NegotiatedPrice ?? _task.Budget)
                    </MudText>
                    @if (_task.NegotiatedPrice.HasValue)
                    {
                        <MudText Typo="Typo.caption" Class="mb-4" Color="Color.Secondary">
                            Original Budget: $@_task.Budget
                        </MudText>
                    }

                    @if (_task.Deadline.HasValue)
                    {
                        <MudText Typo="Typo.subtitle1" Class="mb-2"><strong>Deadline:</strong></MudText>
                        <MudText Typo="Typo.body1" Class="mb-4">
                            @_task.Deadline.Value.ToString("MMM dd, yyyy")
                        </MudText>
                    }

                    <MudText Typo="Typo.subtitle1" Class="mb-2"><strong>Description:</strong></MudText>
                    <MudText Typo="Typo.body1" Class="mb-4">
                        @_task.Description
                    </MudText>

                    <!-- Action Buttons -->
                    <MudDivider Class="my-4" />

                    @if (_isCreator)
                    {
                        @if (_task.Status == SkillTaskStatus.Cancelled)
                        {
                            <MudAlert Severity="Severity.Warning" Class="mb-4">
                                This task has been cancelled.
                            </MudAlert>
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Success"
                                       StartIcon="@Icons.Material.Filled.Publish"
                                       OnClick="RepublishTask">
                                Republish Task
                            </MudButton>
                        }
                        else if (_task.Status == SkillTaskStatus.PendingCompletion)
                        {
                            <MudAlert Severity="Severity.Info" Class="mb-4">
                                The helper has marked this task as complete. Please review and confirm completion.
                            </MudAlert>
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Success"
                                       StartIcon="@Icons.Material.Filled.CheckCircle"
                                       OnClick="ConfirmTaskComplete">
                                Confirm Task Complete
                            </MudButton>
                        }
                        else if (_task.Status == SkillTaskStatus.Completed)
                        {
                            <MudAlert Severity="Severity.Success" Class="mb-4">
                                This task has been completed successfully!
                            </MudAlert>
                            @if (_task.Rating == null)
                            {
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.Star"
                                           OnClick="OpenRatingDialog">
                                    Rate Helper
                                </MudButton>
                            }
                            else
                            {
                                <MudAlert Severity="Severity.Info">
                                    You have already rated this task.
                                </MudAlert>
                            }
                        }
                        else
                        {
                            <div class="d-flex gap-2">
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.Edit"
                                           Href="@($"/task/{_task.Id}/edit")">
                                    Edit
                                </MudButton>
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Error"
                                           StartIcon="@Icons.Material.Filled.Cancel"
                                           OnClick="CancelTask">
                                    Cancel Task
                                </MudButton>
                            </div>
                        }
                    }
                    else if (_isHelper)
                    {
                        @if (_task.Status == SkillTaskStatus.Assigned)
                        {
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Success"
                                       StartIcon="@Icons.Material.Filled.Done"
                                       OnClick="MarkTaskDone">
                                Mark Task as Done
                            </MudButton>
                        }
                        else if (_task.Status == SkillTaskStatus.PendingCompletion)
                        {
                            <MudAlert Severity="Severity.Info" Class="mb-4">
                                Waiting for creator to confirm task completion.
                            </MudAlert>
                        }
                        else if (_task.Status == SkillTaskStatus.Completed)
                        {
                            <MudAlert Severity="Severity.Success" Class="mb-4">
                                Task completed successfully! Payment has been processed.
                            </MudAlert>
                        }
                    }
                    else if (_task.Status == SkillTaskStatus.Assigned && _task.AssignedToId != _currentUserId)
                    {
                        <MudAlert Severity="Severity.Info">
                            This task has been assigned to another user.
                        </MudAlert>
                    }
                    else if (_task.Status == SkillTaskStatus.Open)
                    {
                        @if (UserState.CurrentUser?.Role == UserRole.Company || UserState.CurrentUser?.Role == UserRole.School)
                        {
                            <MudAlert Severity="Severity.Info" Class="mb-4">
                                @(UserState.CurrentUser.Role == UserRole.Company ? "Companies" : "Schools") can only post tasks and jobs, not accept them.
                            </MudAlert>
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Chat"
                                       Href="@($"/chat/{_task.CreatorId}?taskId={_task.Id}")">
                                Open Chat
                            </MudButton>
                        }
                        else
                        {
                            <div class="d-flex flex-wrap gap-2">
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.Chat"
                                           Href="@($"/chat/{_task.CreatorId}?taskId={_task.Id}")">
                                    Open Chat
                                </MudButton>
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Success"
                                           StartIcon="@Icons.Material.Filled.Check"
                                           OnClick="AcceptTask">
                                    Accept Task
                                </MudButton>
                                <MudButton Variant="Variant.Text"
                                           Color="Color.Error"
                                           StartIcon="@Icons.Material.Filled.Report"
                                           OnClick="ReportTask">
                                    Report
                                </MudButton>
                            </div>
                        }
                    }
                </MudPaper>
            </MudItem>

            <!-- Sidebar -->
            <MudItem xs="12" md="4">
                <!-- Location Map -->
                <MudPaper Elevation="2" Class="pa-4 mb-4">
                    <MudText Typo="Typo.h6" GutterBottom="true">Location</MudText>
                    <MudText Typo="Typo.body2" Class="mb-3">@_task.LocationAddress</MudText>

                    @if (_task.Latitude.HasValue && _task.Longitude.HasValue)
                    {
                        <MapComponent @ref="_miniMap"
                                      MapId="taskMap"
                                      Height="250px"
                                      InitialLat="@_task.Latitude.Value"
                                      InitialLng="@_task.Longitude.Value"
                                      InitialZoom="15" />
                    }
                </MudPaper>

                <!-- Task Stats -->
                <MudPaper Elevation="2" Class="pa-4">
                    <MudText Typo="Typo.h6" GutterBottom="true">Task Info</MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem T="string" Icon="@Icons.Material.Filled.DateRange">
                            Posted: @_task.CreatedAt.ToString("MMM dd")
                        </MudListItem>
                        @if (_task.AssignedTo != null)
                        {
                            <MudListItem T="string" Icon="@Icons.Material.Filled.Person">
                                Assigned to: @_task.AssignedTo.Username
                            </MudListItem>
                        }
                        @if (_task.IsDepositPaid)
                        {
                            <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                                Deposit Paid: $@_task.DepositAmount
                            </MudListItem>
                        }
                    </MudList>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudContainer>
}

@code {
    [Parameter]
    public int TaskId { get; set; }

    private SkillTask? _task;
    private MapComponent? _miniMap;
    private int _currentUserId => UserState.CurrentUser?.Id ?? 0;
    private bool _isCreator => _task?.CreatorId == _currentUserId;
    private bool _isHelper => _task?.AssignedToId == _currentUserId;

    protected override async Task OnInitializedAsync()
    {
        _task = await TaskService.GetTaskByIdAsync(TaskId);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _task != null && _miniMap != null)
        {
            await Task.Delay(500);
            if (_task.Latitude.HasValue && _task.Longitude.HasValue)
            {
                await _miniMap.AddMarkerAsync(
                    _task.Id,
                    _task.Latitude.Value,
                    _task.Longitude.Value,
                    _task.Title,
                    "task"
                );
            }
        }
    }

    private async Task AcceptTask()
    {
        if (_task == null) return;

        // Assign task
        var success = await TaskService.AssignTaskAsync(_task.Id, _currentUserId);

        if (success)
        {
            // Calculate 10% deposit based on negotiated price or budget
            var finalPrice = _task.NegotiatedPrice ?? _task.Budget;
            var depositAmount = finalPrice * 0.1m;

            // Process deposit (charge creator, credit helper)
            var depositSuccess = await WalletService.ProcessDepositAsync(_currentUserId, _task.Id, depositAmount);

            if (depositSuccess)
            {
                Snackbar.Add($"Task accepted successfully! The creator was charged a deposit of ${depositAmount:F2}.", Severity.Success);
            }
            else
            {
                Snackbar.Add($"Task accepted, but deposit payment failed. The task creator might not have enough balance for the ${depositAmount:F2} deposit.", Severity.Warning);
            }

            // Reload the task to show updated status
            _task = await TaskService.GetTaskByIdAsync(TaskId);
            StateHasChanged();
        }
        else
        {
            Snackbar.Add("Failed to accept task. Please try again.", Severity.Error);
        }
    }

    private async Task CancelTask()
    {
        if (_task == null) return;

        var success = await TaskService.CancelTaskAsync(_task.Id);

        if (success)
        {
            Snackbar.Add("Task cancelled successfully", Severity.Success);
            // Reload the task to show updated status
            _task = await TaskService.GetTaskByIdAsync(TaskId);
            StateHasChanged();
        }
        else
        {
            Snackbar.Add("Failed to cancel task", Severity.Error);
        }
    }

    private async Task RepublishTask()
    {
        if (_task == null) return;

        var success = await TaskService.RepublishTaskAsync(_task.Id);

        if (success)
        {
            Snackbar.Add("Task republished successfully! It's now visible to everyone.", Severity.Success);
            // Reload the task to show updated status
            _task = await TaskService.GetTaskByIdAsync(TaskId);
            StateHasChanged();
        }
        else
        {
            Snackbar.Add("Failed to republish task", Severity.Error);
        }
    }

    private async Task MarkTaskDone()
    {
        if (_task == null || _currentUserId == 0) return;

        var success = await TaskService.HelperMarkTaskDoneAsync(_task.Id, _currentUserId);

        if (success)
        {
            Snackbar.Add("Task marked as done! Waiting for creator confirmation.", Severity.Success);
            // Reload the task to show updated status
            _task = await TaskService.GetTaskByIdAsync(TaskId);
            StateHasChanged();
        }
        else
        {
            Snackbar.Add("Failed to mark task as done", Severity.Error);
        }
    }

    private async Task ConfirmTaskComplete()
    {
        if (_task == null || _currentUserId == 0) return;

        var success = await TaskService.CreatorConfirmTaskDoneAsync(_task.Id, _currentUserId);

        if (success)
        {
            Snackbar.Add("Task confirmed as complete! Payment has been processed.", Severity.Success);
            // Reload the task to show updated status
            _task = await TaskService.GetTaskByIdAsync(TaskId);
            StateHasChanged();
        }
        else
        {
            Snackbar.Add("Failed to confirm task completion", Severity.Error);
        }
    }

    private async Task OpenRatingDialog()
    {
        if (_task == null || _task.AssignedToId == null) return;

        var parameters = new DialogParameters
        {
            ["TaskId"] = _task.Id,
            ["HelperId"] = _task.AssignedToId.Value,
            ["HelperName"] = _task.AssignedTo?.Username ?? "Helper",
            ["Category"] = _task.Category
        };

        var dialog = await DialogService.ShowAsync<SkillShareMap.Shared.Components.RatingDialog>("Rate Helper", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            // Reload the task to show the rating
            _task = await TaskService.GetTaskByIdAsync(TaskId);
            StateHasChanged();
        }
    }

    private void ReportTask()
    {
        Snackbar.Add("Report feature coming soon!", Severity.Info);
    }

    private string GetCategoryName(TaskCategory category)
    {
        return category switch
        {
            TaskCategory.StudyHelp => "Study Help",
            TaskCategory.TechHelp => "Tech Help",
            TaskCategory.CreativeDesign => "Creative Design",
            TaskCategory.PhotoVideo => "Photo & Video",
            TaskCategory.WritingEditing => "Writing & Editing",
            TaskCategory.LanguageHelp => "Language Help",
            _ => category.ToString()
        };
    }

    private Color GetStatusColor(SkillTaskStatus status)
    {
        return status switch
        {
            SkillTaskStatus.Open => Color.Success,
            SkillTaskStatus.Assigned => Color.Info,
            SkillTaskStatus.PendingDeposit => Color.Warning,
            SkillTaskStatus.PendingCompletion => Color.Warning,
            SkillTaskStatus.Completed => Color.Success,
            SkillTaskStatus.Cancelled => Color.Error,
            _ => Color.Default
        };
    }
}
