@page "/task/{TaskId:int}"
@using SkillShareMap.Services
@using SkillShareMap.Models
@using SkillShareMap.Shared.Components
@inject ITaskService TaskService
@inject IWalletService WalletService
@inject IRatingService RatingService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject UserState UserState

<PageTitle>Task Details</PageTitle>

@if (_task == null)
{
    <div class="d-flex justify-center align-center" style="min-height: 400px;">
        <MudProgressCircular Indeterminate="true" />
    </div>
}
else
{
    <MudContainer MaxWidth="MaxWidth.Large" Class="py-8">
        <MudGrid Spacing="4">
            <MudItem xs="12" md="8">
                <MudPaper Elevation="0" Class="pa-8 rounded-xl" Style="border: 1px solid #e0e0e0;">
                    
                    @if (!string.IsNullOrEmpty(_task.ImageUrl))
                    {
                        <MudImage Src="@_task.ImageUrl"
                                  Alt="@_task.Title"
                                  Height="300"
                                  ObjectFit="ObjectFit.Cover"
                                  Class="rounded-xl mb-6"
                                  Style="width: 100%;" />
                    }

                    <div class="d-flex justify-space-between align-start mb-4">
                        <div>
                            <MudText Typo="Typo.h4" Style="font-weight: 700; color: #1B1B1B; line-height: 1.2;" Class="mb-3">@_task.Title</MudText>
                            <MudChip T="string" Variant="Variant.Text" Color="GetStatusColor(_task.Status)" Size="Size.Small" Class="fw-bold">
                                @_task.Status
                            </MudChip>
                        </div>
                        <div class="pa-2 rounded-circle" style="background-color: #F5F5F5;">
                            <CategoryIcon Category="_task.Category" IconSize="Size.Large" />
                        </div>
                    </div>

                    <MudDivider Class="my-6" />

                    <MudText Typo="Typo.subtitle1" Class="mb-3" Style="font-weight: 700; color: #1B1B1B;">Posted by</MudText>
                    <div class="d-flex align-center mb-6 pa-4 rounded-xl" style="background-color: #F8F9FA;">
                        <MudAvatar Color="Color.Primary" Class="mr-4" Size="Size.Medium">
                            @_task.Creator?.Username?.Substring(0, 1).ToUpper()
                        </MudAvatar>
                        <div>
                            <MudText Typo="Typo.body1" Style="font-weight: 600; color: #1B1B1B;">@_task.Creator?.Username</MudText>
                            @if (_task.Creator != null)
                            {
                                <StarRating Rating="_task.Creator.ReputationLevel" ShowRating="true" />
                            }
                        </div>
                    </div>

                    <MudGrid Class="mb-4">
                        <MudItem xs="12" sm="6">
                            <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mb-1">Category</MudText>
                            <div class="d-flex align-center">
                                <CategoryIcon Category="_task.Category" IconSize="Size.Small" />
                                <MudText Typo="Typo.body1" Class="ml-2" Style="color: #1B1B1B;">@GetCategoryName(_task.Category)</MudText>
                            </div>
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mb-1">
                                @(_task.NegotiatedPrice.HasValue ? "Negotiated Price" : "Budget")
                            </MudText>
                            <MudText Typo="Typo.h5" Style="font-weight: 700; color: #1B1B1B;">
                                $@(_task.NegotiatedPrice ?? _task.Budget)
                            </MudText>
                            @if (_task.NegotiatedPrice.HasValue)
                            {
                                <MudText Typo="Typo.caption" Style="color: #9E9E9E; text-decoration: line-through;">
                                    Original Budget: $@_task.Budget
                                </MudText>
                            }
                        </MudItem>

                        @if (_task.Deadline.HasValue)
                        {
                            <MudItem xs="12">
                                <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mb-1">Deadline</MudText>
                                <MudText Typo="Typo.body1" Style="color: #1B1B1B;">
                                    @_task.Deadline.Value.ToString("MMM dd, yyyy")
                                </MudText>
                            </MudItem>
                        }
                    </MudGrid>

                    <div class="mb-6">
                        <MudText Typo="Typo.subtitle1" Class="mb-2" Style="font-weight: 700; color: #1B1B1B;">Description</MudText>
                        <MudText Typo="Typo.body1" Style="color: #4a4a4a; line-height: 1.6;">
                            @_task.Description
                        </MudText>
                    </div>

                    <MudDivider Class="my-6" />

                    @if (_isCreator)
                    {
                        @if (_task.Status == SkillTaskStatus.Cancelled)
                        {
                            <MudAlert Severity="Severity.Warning" Class="mb-4 rounded-lg" Variant="Variant.Outlined">This task has been cancelled.</MudAlert>
                            <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.Publish" OnClick="RepublishTask" Style="border-radius: 12px;">Republish Task</MudButton>
                        }
                        else if (_task.Status == SkillTaskStatus.PendingCompletion)
                        {
                            <MudAlert Severity="Severity.Info" Class="mb-4 rounded-lg" Variant="Variant.Outlined">The helper has marked this task as complete. Please review and confirm.</MudAlert>
                            <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.CheckCircle" OnClick="ConfirmTaskComplete" Style="border-radius: 12px;">Confirm Task Complete</MudButton>
                        }
                        else if (_task.Status == SkillTaskStatus.Completed)
                        {
                            <MudAlert Severity="Severity.Success" Class="mb-4 rounded-lg" Variant="Variant.Outlined">This task has been completed successfully!</MudAlert>
                            @if (_task.Rating == null)
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Star" OnClick="OpenRatingDialog" Style="border-radius: 12px;">Rate Helper</MudButton>
                            }
                            else
                            {
                                <MudAlert Severity="Severity.Info" Class="rounded-lg">You have already rated this task.</MudAlert>
                            }
                        }
                        else
                        {
                            <div class="d-flex gap-3">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" Href="@($"/task/{_task.Id}/edit")" Style="border-radius: 12px;">Edit</MudButton>
                                <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Cancel" OnClick="CancelTask" Style="border-radius: 12px;">Cancel Task</MudButton>
                            </div>
                        }
                    }
                    else if (_isHelper)
                    {
                        @if (_task.Status == SkillTaskStatus.Assigned)
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.Done" OnClick="MarkTaskDone" Style="border-radius: 12px; padding: 12px 24px;">Mark Task as Done</MudButton>
                        }
                        else if (_task.Status == SkillTaskStatus.PendingCompletion)
                        {
                            <MudAlert Severity="Severity.Info" Class="mb-4 rounded-lg" Variant="Variant.Outlined">Waiting for creator to confirm task completion.</MudAlert>
                        }
                        else if (_task.Status == SkillTaskStatus.Completed)
                        {
                            <MudAlert Severity="Severity.Success" Class="mb-4 rounded-lg" Variant="Variant.Outlined">Task completed successfully! Payment has been processed.</MudAlert>
                        }
                    }
                    else if (_task.Status == SkillTaskStatus.Assigned && _task.AssignedToId != _currentUserId)
                    {
                        <MudAlert Severity="Severity.Info" Class="rounded-lg" Variant="Variant.Outlined">This task has been assigned to another user.</MudAlert>
                    }
                    else if (_task.Status == SkillTaskStatus.Open)
                    {
                        @if (UserState.CurrentUser?.Role == UserRole.Company || UserState.CurrentUser?.Role == UserRole.School)
                        {
                            <MudAlert Severity="Severity.Info" Class="mb-4 rounded-lg" Variant="Variant.Outlined">
                                @(UserState.CurrentUser.Role == UserRole.Company ? "Companies" : "Schools") can only post tasks and jobs, not accept them.
                            </MudAlert>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Chat" Href="@($"/chat/{_task.CreatorId}?taskId={_task.Id}")" Style="border-radius: 12px;">Open Chat</MudButton>
                        }
                        else
                        {
                            <div class="d-flex flex-wrap gap-3">
                                <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Chat" Href="@($"/chat/{_task.CreatorId}?taskId={_task.Id}")" Style="border-radius: 12px; font-weight: 600;">Open Chat</MudButton>
                                
                                <MudButton Variant="Variant.Filled" OnClick="AcceptTask" StartIcon="@Icons.Material.Filled.Check" 
                                           Style="background-color: #1B1B1B; color: white; border-radius: 12px; font-weight: 700; padding: 8px 24px;">
                                    Accept Task
                                </MudButton>
                                
                                <MudButton Variant="Variant.Text" Color="Color.Error" StartIcon="@Icons.Material.Filled.Report" OnClick="ReportTask" Style="border-radius: 12px;">Report</MudButton>
                            </div>
                        }
                    }

                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="4">
                
                <MudPaper Elevation="0" Class="pa-6 mb-6 rounded-xl" Style="border: 1px solid #e0e0e0;">
                    <div class="d-flex align-center mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.LocationOn" Color="Color.Error" Class="mr-2" />
                        <MudText Typo="Typo.h6" Style="font-weight: 700; color: #1B1B1B;">Location</MudText>
                    </div>
                    
                    <MudText Typo="Typo.body2" Class="mb-4" Style="color: #4a4a4a;">@_task.LocationAddress</MudText>

                    <div class="rounded-xl overflow-hidden" style="border: 1px solid #e0e0e0;">
                        @if (_task.Latitude.HasValue && _task.Longitude.HasValue)
                        {
                            <MapComponent @ref="_miniMap"
                                          MapId="taskMap"
                                          Height="250px"
                                          InitialLat="@_task.Latitude.Value"
                                          InitialLng="@_task.Longitude.Value"
                                          InitialZoom="15" />
                        }
                         else
                        {
                             <div class="d-flex align-center justify-center" style="height: 200px; background-color: #f5f5f5; color: #999;">
                                 No map data
                             </div>
                        }
                    </div>
                </MudPaper>

                <MudPaper Elevation="0" Class="pa-6 rounded-xl" Style="border: 1px solid #e0e0e0;">
                    <MudText Typo="Typo.h6" Style="font-weight: 700; color: #1B1B1B;" Class="mb-4">Task Info</MudText>
                    
                    <div class="d-flex flex-column gap-4">
                        
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.DateRange" Size="Size.Small" Style="color: #9E9E9E;" Class="mr-3" />
                            <div>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Posted</MudText>
                                <MudText Typo="Typo.body2" Style="font-weight: 500; color: #1B1B1B;">@_task.CreatedAt.ToString("MMM dd")</MudText>
                            </div>
                        </div>
                        
                        <MudDivider />

                        @if (_task.AssignedTo != null)
                        {
                            <div class="d-flex align-center">
                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Style="color: #9E9E9E;" Class="mr-3" />
                                <div>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Assigned to</MudText>
                                    <MudText Typo="Typo.body2" Style="font-weight: 500; color: #1B1B1B;">@_task.AssignedTo.Username</MudText>
                                </div>
                            </div>
                            <MudDivider />
                        }

                        @if (_task.IsDepositPaid)
                        {
                            <div class="d-flex align-center">
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" Class="mr-3" />
                                <div>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Security</MudText>
                                    <MudText Typo="Typo.body2" Style="font-weight: 700; color: var(--mud-palette-success);">Deposit Paid ($@_task.DepositAmount)</MudText>
                                </div>
                            </div>
                        }
                        else
                        {
                             <div class="d-flex align-center">
                                <MudIcon Icon="@Icons.Material.Outlined.Info" Size="Size.Small" Color="Color.Default" Class="mr-3" />
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Deposit not yet paid</MudText>
                            </div>
                        }

                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudContainer>
}

@code {
    [Parameter]
    public int TaskId { get; set; }

    private SkillTask? _task;
    private MapComponent? _miniMap;
    private int _currentUserId => UserState.CurrentUser?.Id ?? 0;
    private bool _isCreator => _task?.CreatorId == _currentUserId;
    private bool _isHelper => _task?.AssignedToId == _currentUserId;

    protected override async Task OnInitializedAsync()
    {
        _task = await TaskService.GetTaskByIdAsync(TaskId);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _task != null && _miniMap != null)
        {
            await Task.Delay(500);
            if (_task.Latitude.HasValue && _task.Longitude.HasValue)
            {
                await _miniMap.AddMarkerAsync(
                    _task.Id,
                    _task.Latitude.Value,
                    _task.Longitude.Value,
                    _task.Title,
                    "task"
                );
            }
        }
    }

    private async Task AcceptTask()
    {
        if (_task == null) return;

        // Assign task
        var success = await TaskService.AssignTaskAsync(_task.Id, _currentUserId);

        if (success)
        {
            // Calculate 10% deposit based on negotiated price or budget
            var finalPrice = _task.NegotiatedPrice ?? _task.Budget;
            var depositAmount = finalPrice * 0.1m;

            // Process deposit (charge creator, credit helper)
            var depositSuccess = await WalletService.ProcessDepositAsync(_currentUserId, _task.Id, depositAmount);

            if (depositSuccess)
            {
                Snackbar.Add($"Task accepted successfully! The creator was charged a deposit of ${depositAmount:F2}.", Severity.Success);
            }
            else
            {
                Snackbar.Add($"Task accepted, but deposit payment failed. The task creator might not have enough balance for the ${depositAmount:F2} deposit.", Severity.Warning);
            }

            // Reload the task to show updated status
            _task = await TaskService.GetTaskByIdAsync(TaskId);
            StateHasChanged();
        }
        else
        {
            Snackbar.Add("Failed to accept task. Please try again.", Severity.Error);
        }
    }

    private async Task CancelTask()
    {
        if (_task == null) return;

        var success = await TaskService.CancelTaskAsync(_task.Id);

        if (success)
        {
            Snackbar.Add("Task cancelled successfully", Severity.Success);
            // Reload the task to show updated status
            _task = await TaskService.GetTaskByIdAsync(TaskId);
            StateHasChanged();
        }
        else
        {
            Snackbar.Add("Failed to cancel task", Severity.Error);
        }
    }

    private async Task RepublishTask()
    {
        if (_task == null) return;

        var success = await TaskService.RepublishTaskAsync(_task.Id);

        if (success)
        {
            Snackbar.Add("Task republished successfully! It's now visible to everyone.", Severity.Success);
            // Reload the task to show updated status
            _task = await TaskService.GetTaskByIdAsync(TaskId);
            StateHasChanged();
        }
        else
        {
            Snackbar.Add("Failed to republish task", Severity.Error);
        }
    }

    private async Task MarkTaskDone()
    {
        if (_task == null || _currentUserId == 0) return;

        var success = await TaskService.HelperMarkTaskDoneAsync(_task.Id, _currentUserId);

        if (success)
        {
            Snackbar.Add("Task marked as done! Waiting for creator confirmation.", Severity.Success);
            // Reload the task to show updated status
            _task = await TaskService.GetTaskByIdAsync(TaskId);
            StateHasChanged();
        }
        else
        {
            Snackbar.Add("Failed to mark task as done", Severity.Error);
        }
    }

    private async Task ConfirmTaskComplete()
    {
        if (_task == null || _currentUserId == 0) return;

        var success = await TaskService.CreatorConfirmTaskDoneAsync(_task.Id, _currentUserId);

        if (success)
        {
            Snackbar.Add("Task confirmed as complete! Payment has been processed.", Severity.Success);
            // Reload the task to show updated status
            _task = await TaskService.GetTaskByIdAsync(TaskId);
            StateHasChanged();
        }
        else
        {
            Snackbar.Add("Failed to confirm task completion", Severity.Error);
        }
    }

    private async Task OpenRatingDialog()
    {
        if (_task == null || _task.AssignedToId == null) return;

        var parameters = new DialogParameters
        {
            ["TaskId"] = _task.Id,
            ["HelperId"] = _task.AssignedToId.Value,
            ["HelperName"] = _task.AssignedTo?.Username ?? "Helper",
            ["Category"] = _task.Category
        };

        var dialog = await DialogService.ShowAsync<SkillShareMap.Shared.Components.RatingDialog>("Rate Helper", parameters);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            // Reload the task to show the rating
            _task = await TaskService.GetTaskByIdAsync(TaskId);
            StateHasChanged();
        }
    }

    private void ReportTask()
    {
        Snackbar.Add("Report feature coming soon!", Severity.Info);
    }

    private string GetCategoryName(TaskCategory category)
    {
        return category switch
        {
            TaskCategory.StudyHelp => "Study Help",
            TaskCategory.TechHelp => "Tech Help",
            TaskCategory.CreativeDesign => "Creative Design",
            TaskCategory.PhotoVideo => "Photo & Video",
            TaskCategory.WritingEditing => "Writing & Editing",
            TaskCategory.LanguageHelp => "Language Help",
            _ => category.ToString()
        };
    }

    private Color GetStatusColor(SkillTaskStatus status)
    {
        return status switch
        {
            SkillTaskStatus.Open => Color.Success,
            SkillTaskStatus.Assigned => Color.Info,
            SkillTaskStatus.PendingDeposit => Color.Warning,
            SkillTaskStatus.PendingCompletion => Color.Warning,
            SkillTaskStatus.Completed => Color.Success,
            SkillTaskStatus.Cancelled => Color.Error,
            _ => Color.Default
        };
    }
}
