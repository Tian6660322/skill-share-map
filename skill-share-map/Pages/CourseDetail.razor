@page "/course/{CourseId:int}"
@using SkillShareMap.Models
@using SkillShareMap.Services
@inject ICourseService CourseService
@inject NavigationManager Navigation

<PageTitle>Course Details</PageTitle>

@if (_isLoading)
{
    <div class="d-flex justify-center align-center" style="min-height: 300px;">
        <MudProgressCircular Size="Size.Large" Indeterminate="true" />
    </div>
}
else if (_course is null)
{
    <MudContainer MaxWidth="MaxWidth.Small" Class="my-8">
        <MudPaper Elevation="0" Class="cr-empty">
            <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Size="Size.Large" Color="Color.Error" />
            <MudText Typo="Typo.h5" Class="mt-3" GutterBottom="true">Course not found</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                The course you are looking for is no longer available.
            </MudText>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       OnClick="GoBack">
                Back to Classroom
            </MudButton>
        </MudPaper>
    </MudContainer>
}
else
{
    <div class="cd-page">

        <!-- Back -->
        <MudButton Variant="Variant.Text"
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   Color="Color.Primary"
                   OnClick="GoBack"
                   Class="mb-4"
                   Size="Size.Small">
            Back to Classroom
        </MudButton>

        <!-- Hero Banner -->
        <div class="cd-hero" style="background: linear-gradient(135deg, @GetCategoryGradientStart(_course.Category), @GetCategoryGradientEnd(_course.Category));">
            <div class="cd-hero__icon-wrap">
                <MudIcon Icon="@GetCategoryIcon(_course.Category)" Style="font-size:2.8rem; color:rgba(255,255,255,0.9);" />
            </div>
            <div class="cd-hero__text">
                <div class="cd-hero__chips">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                             Style="background:rgba(255,255,255,0.2); color:#fff; backdrop-filter:blur(4px);">
                        @GetCategoryName(_course.Category)
                    </MudChip>
                    <MudChip T="string" Size="Size.Small"
                             Color="@GetDifficultyColor(_course.Difficulty)"
                             Variant="Variant.Filled">
                        @_course.Difficulty
                    </MudChip>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                             Style="border-color:rgba(255,255,255,0.3); color:#fff;">
                        <MudIcon Icon="@GetTypeIcon(_course.Type)" Size="Size.Small" Class="mr-1" />
                        @GetTypeName(_course.Type)
                    </MudChip>
                </div>
                <h1 class="cd-hero__title">@_course.Title</h1>
            </div>
        </div>

        <!-- Content Layout -->
        <div class="cd-layout">

            <!-- Main -->
            <div class="cd-main">
                <MudPaper Elevation="0" Class="cd-section-card">
                    <MudText Typo="Typo.subtitle1" Style="font-weight:700;" Class="mb-2">Overview</MudText>
                    <MudText Typo="Typo.body1" Color="Color.Secondary" Style="line-height:1.75;">
                        @_course.Description
                    </MudText>
                </MudPaper>

                @if (!string.IsNullOrWhiteSpace(_course.ExternalUrl))
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Launch"
                               Href="@_course.ExternalUrl"
                               Target="_blank"
                               Class="mt-4"
                               Style="border-radius:12px; text-transform:none; font-weight:600; padding:10px 24px;">
                        Open Learning Resource
                    </MudButton>
                }
            </div>

            <!-- Sidebar -->
            <div class="cd-sidebar">
                <MudPaper Elevation="0" Class="cd-info-card">
                    <div class="cd-info-row">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Color="Color.Secondary" />
                        <div>
                            <div class="cd-info-label">Instructor</div>
                            <div class="cd-info-value">@(_course.InstructorName ?? "TBA")</div>
                        </div>
                    </div>
                    <div class="cd-info-row">
                        <MudIcon Icon="@Icons.Material.Filled.AccessTime" Size="Size.Small" Color="Color.Secondary" />
                        <div>
                            <div class="cd-info-label">Duration</div>
                            <div class="cd-info-value">@(_course.Duration ?? "TBA")</div>
                        </div>
                    </div>
                    <div class="cd-info-row">
                        <MudIcon Icon="@GetTypeIcon(_course.Type)" Size="Size.Small" Color="Color.Secondary" />
                        <div>
                            <div class="cd-info-label">Format</div>
                            <div class="cd-info-value">@GetTypeName(_course.Type)</div>
                        </div>
                    </div>
                    <div class="cd-info-row">
                        <MudIcon Icon="@Icons.Material.Filled.BarChart" Size="Size.Small" Color="Color.Secondary" />
                        <div>
                            <div class="cd-info-label">Difficulty</div>
                            <div class="cd-info-value">@_course.Difficulty</div>
                        </div>
                    </div>
                </MudPaper>
            </div>
        </div>

    </div>
}

@code {
    [Parameter]
    public int CourseId { get; set; }

    private Course? _course;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        _course = await CourseService.GetCourseByIdAsync(CourseId);
        _isLoading = false;
    }

    private void GoBack() => Navigation.NavigateTo("/classroom");

    private string GetCategoryName(TaskCategory category) => category switch
    {
        TaskCategory.StudyHelp => "Study Help",
        TaskCategory.TechHelp => "Tech Help",
        TaskCategory.CreativeDesign => "Creative Design",
        TaskCategory.PhotoVideo => "Photo & Video",
        TaskCategory.WritingEditing => "Writing & Editing",
        TaskCategory.LanguageHelp => "Language Help",
        _ => category.ToString()
    };

    private string GetCategoryIcon(TaskCategory category) => category switch
    {
        TaskCategory.StudyHelp => Icons.Material.Filled.MenuBook,
        TaskCategory.TechHelp => Icons.Material.Filled.Computer,
        TaskCategory.CreativeDesign => Icons.Material.Filled.Brush,
        TaskCategory.PhotoVideo => Icons.Material.Filled.PhotoCamera,
        TaskCategory.WritingEditing => Icons.Material.Filled.Edit,
        TaskCategory.LanguageHelp => Icons.Material.Filled.Translate,
        _ => Icons.Material.Filled.Category
    };

    private string GetCategoryGradientStart(TaskCategory category) => category switch
    {
        TaskCategory.StudyHelp => "#667eea",
        TaskCategory.TechHelp => "#0ea5e9",
        TaskCategory.CreativeDesign => "#e879a8",
        TaskCategory.PhotoVideo => "#f59e0b",
        TaskCategory.WritingEditing => "#8b5cf6",
        TaskCategory.LanguageHelp => "#34d399",
        _ => "#667eea"
    };

    private string GetCategoryGradientEnd(TaskCategory category) => category switch
    {
        TaskCategory.StudyHelp => "#764ba2",
        TaskCategory.TechHelp => "#2563eb",
        TaskCategory.CreativeDesign => "#c084fc",
        TaskCategory.PhotoVideo => "#ef4444",
        TaskCategory.WritingEditing => "#6366f1",
        TaskCategory.LanguageHelp => "#06b6d4",
        _ => "#764ba2"
    };

    private string GetTypeName(CourseType type) => type switch
    {
        CourseType.OnlineCourse => "Online Course",
        CourseType.Workshop => "Workshop",
        CourseType.WebSeminar => "Web Seminar",
        CourseType.Tutorial => "Tutorial",
        _ => type.ToString()
    };

    private string GetTypeIcon(CourseType type) => type switch
    {
        CourseType.OnlineCourse => Icons.Material.Filled.OndemandVideo,
        CourseType.Workshop => Icons.Material.Filled.Groups,
        CourseType.WebSeminar => Icons.Material.Filled.Videocam,
        CourseType.Tutorial => Icons.Material.Filled.PlayCircle,
        _ => Icons.Material.Filled.School
    };

    private Color GetDifficultyColor(DifficultyLevel difficulty) => difficulty switch
    {
        DifficultyLevel.Beginner => Color.Success,
        DifficultyLevel.Intermediate => Color.Warning,
        DifficultyLevel.Advanced => Color.Error,
        DifficultyLevel.Expert => Color.Error,
        _ => Color.Default
    };
}
